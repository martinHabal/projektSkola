                //nacte svatky pres API
                const nactiSvatky = async () => {
                    const res = await fetch("https://date.nager.at/api/v3/PublicHolidays/2026/CZ");
                    const data = await res.json();
                    return data.map(({ date, localName }) => ({
                        day: new Date(date).getDate(),
