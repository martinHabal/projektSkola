                //implementace scriptů z vykaz-novy do staryho
                // Naplnění školních roků do optionu    
            function populateSchoolYears() {
                const currentYear = new Date().getFullYear();
                const startYear = currentYear - 5;
                const endYear = currentYear + 5;
                schoolYearSelect.innerHTML = '';
                for (let y = startYear; y <= endYear; y++) {
                    const option = document.createElement('option');
                    option.value = y;
                    option.textContent = `${y}/${y + 1}`;
                    if (y === currentYear && new Date().getMonth() >= 8) option.selected = true;
                    else if (y === currentYear - 1 && new Date().getMonth() < 8) option.selected = true;
                    schoolYearSelect.appendChild(option);
                }
            }
