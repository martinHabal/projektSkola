                    // Aktualizovat informace o uživateli
                    const userName = document.getElementById('user-name').value || loadUserName();
                    document.getElementById('print-user-info').innerHTML = `
                <p><strong>Pedagogický pracovník:</strong> ${userName}</p>
                <p><strong>Měsíc:</strong> ${monthNames[month]} ${year}</p>
            `;

                    // Aktualizovat podpis s jménem uživatele
                    updatePrintSignature();

                    // Načíst data z aktuální tabulky
                    const rows = document.querySelectorAll('#calendar-container tbody tr:not(.total-row)');
                    const tableBody = document.getElementById('print-table-body');
                    tableBody.innerHTML = '';

                    let totalWorkHours = 0;
                    let totalSubstituteHours = 0;
                    let totalMissedHours = 0;

                    rows.forEach(row => {
                        const cells = row.cells;
                        const date = cells[0].textContent;
                        const day = cells[1].textContent;
                        const dayType = cells[2].textContent;

                        // Odpracované hodiny
                        const workHours = parseFloat(cells[3].querySelector('.hours-display').textContent) || 0;
                        totalWorkHours += workHours;

                        // Suplované hodiny
                        const substituteInput = cells[4].querySelector('.substitute-input');
                        const substituteHours = substituteInput ? parseFloat(substituteInput.value) || 0 : 0;
                        totalSubstituteHours += substituteHours;

                        // Neodučené hodiny
                        const missedInput = cells[5].querySelector('.missed-input');
                        const missedHours = missedInput ? parseFloat(missedInput.value) || 0 : 0;
                        totalMissedHours += missedHours;

                        // Důvod
                        const reasonSelect = cells[6].querySelector('.reason-select');
                        let reason = '-';
                        if (reasonSelect && reasonSelect.value) {
                            const reasonId = reasonSelect.value;
                            const reasonObj = missedReasons.find(r => r.id === reasonId);
                            reason = reasonObj ? reasonObj.name : '-';
                        }

                        // Určit CSS třídu pro typ dne
                        let dayClass = '';
                        if (dayType === 'Víkend') dayClass = 'print-weekend';
                        else if (dayType === 'Státní svátek') dayClass = 'print-holiday';
                        else if (dayType.includes('prázdniny')) dayClass = 'print-vacation';

                        // Vytvořit řádek pro tisk
                        const tr = document.createElement('tr');
                        if (dayClass) tr.className = dayClass;

                        tr.innerHTML = `
                    <td>${date}</td>
                    <td>${day}</td>
                    <td>${dayType}</td>
                    <td>${workHours}</td>
                    <td>${substituteHours}</td>
                    <td>${missedHours}</td>
                    <td>${reason}</td>
                `;

                        tableBody.appendChild(tr);
                    });

                    // Přidat součtový řádek
                    const totalRow = document.createElement('tr');
                    totalRow.className = 'print-total';
                    totalRow.innerHTML = `
                <td colspan="3"><strong>CELKEM</strong></td>
                <td><strong>${totalWorkHours}</strong></td>
                <td><strong>${totalSubstituteHours}</strong></td>
                <td><strong>${totalMissedHours}</strong></td>
                <td></td>
            `;
                    tableBody.appendChild(totalRow);
                }

                // Aktualizuje podpis v tiskové verzi
                function updatePrintSignature() {
                    const userName = document.getElementById('user-name').value || loadUserName();
                    document.getElementById('print-user-name').textContent = `Podpis: ${userName}`;
                }

                // Zobrazí modal pro odeslání e-mailem
                function showEmailModal() {
                    const month = currentMonth;
                    const year = currentYear;
                    const monthNames = [
                        "Leden", "Únor", "Březen", "Duben", "Květen", "Červen",
                        "Červenec", "Srpen", "Září", "Říjen", "Listopad", "Prosinec"
                    ];

                    const userName = document.getElementById('user-name').value || loadUserName();

                    // Nastavit předmět e-mailu
                    document.getElementById('emailSubject').value = `Výkaz pracovní doby - ${monthNames[month]} ${year}`;

                    // Načíst data a vytvořit tělo zprávy
                    const rows = document.querySelectorAll('#calendar-container tbody tr:not(.total-row)');
                    let emailBody = `Vážení,\n\nzasílám Vám výkaz pracovní doby za měsíc ${monthNames[month]} ${year}.\n\n`;
                    emailBody += "Detailní přehled:\n\n";

                    let totalWorkHours = 0;
                    let totalSubstituteHours = 0;
                    let totalMissedHours = 0;

                    // Přidat souhrn neoducených hodin
                    const missedDays = [];
                    rows.forEach(row => {
                        const cells = row.cells;
                        const missedInput = cells[5].querySelector('.missed-input');
                        const missedHours = missedInput ? parseFloat(missedInput.value) || 0 : 0;

                        if (missedHours > 0) {
                            const date = cells[0].textContent;
                            const reasonSelect = cells[6].querySelector('.reason-select');
                            let reason = 'Neznámý důvod';

                            if (reasonSelect && reasonSelect.value) {
                                const reasonId = reasonSelect.value;
                                const reasonObj = missedReasons.find(r => r.id === reasonId);
                                reason = reasonObj ? reasonObj.name : 'Neznámý důvod';
                            }

                            missedDays.push({
                                date: date,
                                hours: missedHours,
                                reason: reason
                            });

                            totalMissedHours += missedHours;
                        }

                        // Spočítat ostatní hodiny
                        const workHours = parseFloat(cells[3].querySelector('.hours-display').textContent) || 0;
                        totalWorkHours += workHours;

                        const substituteInput = cells[4].querySelector('.substitute-input');
                        const substituteHours = substituteInput ? parseFloat(substituteInput.value) || 0 : 0;
                        totalSubstituteHours += substituteHours;
                    });

                    // Přidat souhrn
                    emailBody += "Souhrn:\n";
                    emailBody += `Odpracované hodiny: ${totalWorkHours}\n`;
                    emailBody += `Suplované hodiny: ${totalSubstituteHours}\n`;
                    emailBody += `Neodučené hodiny: ${totalMissedHours}\n`;
                    emailBody += `Celkem hodin: ${totalWorkHours + totalSubstituteHours}\n\n`;

                    // Přidat neoducené hodiny
                    if (missedDays.length > 0) {
                        emailBody += "Neodučené hodiny:\n";
                        missedDays.forEach(day => {
                            emailBody += `${day.date}: ${day.hours} hodin (${day.reason})\n`;
                        });
                        emailBody += "\n";
                    }

                    emailBody += "Prohlášení: Potvrzuji, že všechny údaje uvedené v tomto výkazu jsou správné a úplné.\n\n";
                    emailBody += `S pozdravem,\n\n${userName}`;

                    document.getElementById('emailMessage').value = emailBody;

                    // Zobrazit modal
                    document.getElementById('emailModal').style.display = 'flex';
                }

                // Skryje modal pro odeslání e-mailem
                function hideEmailModal() {
                    document.getElementById('emailModal').style.display = 'none';
                }

                // Odeslání e-mailem pomocí webového formuláře
                function sendEmail() {
                    const recipientEmail = document.getElementById('recipientEmail').value;
                    const subject = document.getElementById('emailSubject').value;
                    const message = document.getElementById('emailMessage').value;

                    // Zde by bylo volání na backend pro odeslání e-mailu
                    // Pro demo účely ukážeme pouze potvrzení

                    // Simulace odeslání (v reálném nasazení byste použili např. EmailJS, SMTP server, atd.)
                    alert(`E-mail byl odeslán na adresu: ${recipientEmail}\n\nV reálné aplikaci by zde bylo odeslání e-mailu pomocí backendového API.`);

                    // Resetovat formulář a skrýt modal
                    document.getElementById('emailForm').reset();
                    hideEmailModal();
                }

                // Načte rozvrh do UI
                function loadScheduleToUI() {
                    const schedule = loadScheduleFromStorage();
                    document.getElementById('schedule-mon').value = schedule[1] || 8;
                    document.getElementById('schedule-tue').value = schedule[2] || 8;
                    document.getElementById('schedule-wed').value = schedule[3] || 8;
                    document.getElementById('schedule-thu').value = schedule[4] || 8;
                    document.getElementById('schedule-fri').value = schedule[5] || 8;
                }

                // Načte jméno uživatele do UI
                function loadUserNameToUI() {
                    const userName = loadUserName();
                    document.getElementById('user-name').value = userName;
                    updatePrintSignature();
                }

                // Aktualizuje rozvrh z UI a uloží ho
                function updateSchedule() {
                    currentSchedule = {
                        0: 0,
                        1: parseFloat(document.getElementById('schedule-mon').value) || 0,
                        2: parseFloat(document.getElementById('schedule-tue').value) || 0,
                        3: parseFloat(document.getElementById('schedule-wed').value) || 0,
                        4: parseFloat(document.getElementById('schedule-thu').value) || 0,
                        5: parseFloat(document.getElementById('schedule-fri').value) || 0,
                        6: 0
                    };

                    saveScheduleToStorage(currentSchedule);
                    updateTotals();
                }

                // Vygeneruje kalendář
                function generateCalendar(month, year) {
                    const container = document.getElementById('calendar-container');
                    const daysInMonth = new Date(year, month + 1, 0).getDate();

                    let html = `
                <table id="workTable">
                    <thead>
                        <tr>
                            <th>Datum</th>
                            <th>Den</th>
                            <th>Typ dne</th>
                            <th>Odpracované hodiny</th>
                            <th>Suplované hodiny</th>
                            <th>Neodučené hodiny</th>
                            <th>Důvod neoducení</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

                    const savedData = loadMonthData(month, year);

                    for (let day = 1; day <= daysInMonth; day++) {
                        const date = new Date(year, month, day);
                        const dayOfWeek = date.getDay();
                        const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
                        const isToday = isSameDay(date, new Date());
                        const holidayInfo = getHolidayInfo(day, month, date);
                        const isHoliday = holidayInfo !== null;
                        const vacationInfo = isSchoolVacation(date);
                        const isVacation = vacationInfo !== null;

                        let dayType = "Pracovní den";
                        let cssClass = "workday";

                        if (isWeekend) cssClass = "weekend", dayType = "Víkend";
                        if (isHoliday) cssClass = "holiday", dayType = "Státní svátek";
                        if (isVacation) cssClass = "vacation", dayType = vacationInfo;

                        const dayNames = ["Neděle", "Pondělí", "Úterý", "Středa", "Čtvrtek", "Pátek", "Sobota"];
                        const workHours = (!isWeekend && !isHoliday && !isVacation) ? (currentSchedule[dayOfWeek] || 0) : 0;

                        const savedSubstitute = savedData.substituteHours && savedData.substituteHours[day] ? savedData.substituteHours[day] : "";
                        const savedMissed = savedData.missedHours && savedData.missedHours[day] ? savedData.missedHours[day] : "";
                        const savedReason = savedData.missedReasons && savedData.missedReasons[day] ? savedData.missedReasons[day] : "";

                        const canHaveSubstitute = (!isWeekend && !isHoliday && !isVacation);
                        const canHaveMissed = (!isWeekend && !isHoliday && !isVacation);

                        let reasonOptions = '<option value="">-- vyberte --</option>';
                        missedReasons.forEach(reason => {
                            const selected = savedReason === reason.id ? 'selected' : '';
                            reasonOptions += `<option value="${reason.id}" ${selected}>${reason.name}</option>`;
                        });

                        let reasonHintHtml = '';
                        if (canHaveMissed) {
                            reasonHintHtml = `
                        <div class="reason-select-wrapper">
                            <select class="reason-select" data-day="${day}">
                                ${reasonOptions}
                            </select>
                            <div class="reason-hint">
                                <span class="hint-icon">?</span>
                                <div class="hint-text">
                                    <strong>Nápověda k důvodům:</strong><br>
                                    ${missedReasons.map(reason =>
                                `<strong>${reason.name}:</strong> ${reason.hint}<br>`
                            ).join('')}
                                </div>
                            </div>
                        </div>
                    `;
                        }

                        html += `
                    <tr class="${cssClass} ${isToday ? 'today' : ''}">
                        <td class="day-header">${day}. ${month + 1}. ${year}</td>
                        <td>${dayNames[dayOfWeek]}</td>
                        <td>${dayType}</td>
                        <td><span class="hours-display">${workHours}</span></td>
                        <td>
                            ${canHaveSubstitute ?
                                `<input type="number" min="0" max="24" value="${savedSubstitute}" class="substitute-input" data-day="${day}">` :
                                `<span>-</span>`}
                        </td>
                        <td>
                            ${canHaveMissed ?
                                `<input type="number" min="0" max="24" value="${savedMissed}" class="missed-input" data-day="${day}">` :
                                `<span>-</span>`}
                        </td>
                        <td>
                            ${canHaveMissed ? reasonHintHtml : `<span>-</span>`}
                        </td>
                    </tr>
                `;
                    }

                    html += `
                    <tr class="total-row">
                        <td colspan="3"><strong>CELKEM</strong></td>
                        <td><strong id="table-total-hours">0</strong></td>
                        <td><strong id="table-total-substitute">0</strong></td>
                        <td><strong id="table-total-missed">0</strong></td>
                        <td></td>
                    </tr>
                </tbody>
            </table>
            `;

                    container.innerHTML = html;
                    addEventListeners();
                    updateTotals();
                    loadDataFromLocal();
                }

                // Přidá event listeners
                function addEventListeners() {
                    document.addEventListener('input', function (e) {
                        if (e.target.classList.contains('substitute-input') ||
                            e.target.classList.contains('missed-input') ||
                            e.target.classList.contains('reason-select')) {
                            updateTotals();
                            saveDataToLocal();
                        }
                    });
                }

                // Kontrola stejného dne
                function isSameDay(date1, date2) {
                    return date1.getDate() === date2.getDate() &&
                        date1.getMonth() === date2.getMonth() &&
                        date1.getFullYear() === date2.getFullYear();
                }

                // Zjistí svátek
                function getHolidayInfo(day, month, date) {
                    for (const holiday of fixedHolidays) {
                        if (holiday.day === day - 1 && holiday.month === month) {
                            return holiday;
                        }
                    }

                    if (isEasterHoliday(date)) {
                        return { name: "Velikonoční pondělí" };
                    }

                    return null;
                }

                // Velikonoční svátek
                function isEasterHoliday(date) {
                    const year = date.getFullYear();
                    const a = year % 19;
                    const b = Math.floor(year / 100);
                    const c = year % 100;
                    const d = Math.floor(b / 4);
                    const e = b % 4;
                    const f = Math.floor((b + 8) / 25);
                    const g = Math.floor((b - f + 1) / 3);
                    const h = (19 * a + b - d - g + 15) % 30;
                    const i = Math.floor(c / 4);
                    const k = c % 4;
                    const l = (32 + 2 * e + 2 * i - h - k) % 7;
                    const m = Math.floor((a + 11 * h + 22 * l) / 451);
                    const easterMonth = Math.floor((h + l - 7 * m + 114) / 31) - 1;
                    const easterDay = ((h + l - 7 * m + 114) % 31) + 1;

                    const easterMonday = new Date(year, easterMonth, easterDay + 1);
                    return isSameDay(date, easterMonday);
                }

                // Školní prázdniny
                function isSchoolVacation(date) {
                    const year = date.getFullYear();
                    const month = date.getMonth();
                    const day = date.getDate();

                    for (const vacation of schoolVacations) {
                        let fromYear = year;
                        let toYear = year;

                        if (vacation.fromMonth > vacation.toMonth) {
                            if (month >= vacation.fromMonth) {
                                toYear = year + 1;
                            } else if (month <= vacation.toMonth) {
                                fromYear = year - 1;
                            }
                        }

                        const fromDate = new Date(fromYear, vacation.fromMonth, vacation.fromDay);
                        const toDate = new Date(toYear, vacation.toMonth, vacation.toDay);

                        if (date >= fromDate && date <= toDate) {
                            return vacation.name;
                        }
                    }

                    return null;
                }

                // Aktualizuje součty
                function updateTotals() {
                    const workHourDisplays = document.querySelectorAll('.hours-display');
                    const substituteInputs = document.querySelectorAll('.substitute-input');
                    const missedInputs = document.querySelectorAll('.missed-input');

                    let totalWorkHours = 0;
                    let totalSubstituteHours = 0;
                    let totalMissedHours = 0;

                    workHourDisplays.forEach(display => {
                        totalWorkHours += parseFloat(display.textContent) || 0;
                    });

                    substituteInputs.forEach(input => {
                        totalSubstituteHours += parseFloat(input.value) || 0;
                    });

                    missedInputs.forEach(input => {
                        totalMissedHours += parseFloat(input.value) || 0;
                    });

                    // Aktualizace tabulkových součtů
                    document.getElementById('table-total-hours').textContent = totalWorkHours;
                    document.getElementById('table-total-substitute').textContent = totalSubstituteHours;
                    document.getElementById('table-total-missed').textContent = totalMissedHours;

                    // Výpočet dalších statistik
                    const totalAllHours = totalWorkHours + totalSubstituteHours;

                    // Aktualizace souhrnu v pravém sloupci
                    document.getElementById('preview-total-hours').textContent = totalWorkHours;
                    document.getElementById('preview-total-substitute').textContent = totalSubstituteHours;
                    document.getElementById('preview-total-missed').textContent = totalMissedHours;
                    document.getElementById('preview-total-all').textContent = totalAllHours;

                    // Aktualizace náhledu
                    updateMissedSummary();
                }

                // Aktualizuje souhrn neoducených hodin
                function updateMissedSummary() {
                    const missedInputs = document.querySelectorAll('.missed-input');
                    let missedDays = [];

                    missedInputs.forEach(input => {
                        const value = parseFloat(input.value) || 0;
                        if (value > 0) {
                            const day = input.getAttribute('data-day');
                            const row = input.closest('tr');
                            const dateCell = row.querySelector('.day-header');
                            const dateText = dateCell.textContent;
                            const reasonSelect = document.querySelector(`.reason-select[data-day="${day}"]`);
                            let reasonName = "Neznámý důvod";

                            if (reasonSelect && reasonSelect.value) {
                                const reasonId = reasonSelect.value;
                                const reason = missedReasons.find(r => r.id === reasonId);
                                if (reason) reasonName = reason.name;
                            }

                            missedDays.push({
                                dateText: dateText,
                                hours: value,
                                reason: reasonName
                            });
                        }
                    });

                    const previewContainer = document.getElementById('preview-content');

                    if (missedDays.length === 0) {
                        previewContainer.innerHTML = '<div class="no-missed-days">Žádné neoducené hodiny nebyly zaznamenány</div>';
                    } else {
                        let previewHtml = '';
                        let totalMissed = 0;

                        // Seřadit dny podle data
                        missedDays.sort((a, b) => {
                            const aDay = parseInt(a.dateText.split('.')[0]);
                            const bDay = parseInt(b.dateText.split('.')[0]);
                            return aDay - bDay;
                        });

                        // Omezit počet zobrazených dnů v náhledu pro přehlednost
                        const displayDays = missedDays.slice(0, 8);

                        displayDays.forEach(day => {
                            previewHtml += `
                        <div class="preview-item">
                            <div class="preview-date">${day.dateText}</div>
                            <div class="preview-hours">${day.hours} hodin</div>
                            <div class="preview-reason">${day.reason}</div>
                        </div>
                    `;

                            totalMissed += day.hours;
                        });

                        // Pokud je více dnů než 8, přidat informaci
                        if (missedDays.length > 8) {
                            previewHtml += `
                        <div class="more-days">
                            + dalších ${missedDays.length - 8} dnů
                        </div>
                    `;
                        }

                        // Přidat celkový součet
                        previewHtml += `
                    <div class="preview-total">
                        <div class="preview-total-label">Celkem neoducených hodin:</div>
                        <div class="preview-total-value">${totalMissed} hodin</div>
                    </div>
                `;

                        previewContainer.innerHTML = previewHtml;
                    }
                }

                // Uloží data do localStorage
                function saveDataToLocal() {
                    const month = currentMonth;
                    const year = currentYear;

                    const data = {
                        month: month,
                        year: year,
                        substituteHours: {},
                        missedHours: {},
                        missedReasons: {}
                    };

                    document.querySelectorAll('.substitute-input').forEach(input => {
                        const day = input.getAttribute('data-day');
                        data.substituteHours[day] = input.value;
                    });

                    document.querySelectorAll('.missed-input').forEach(input => {
                        const day = input.getAttribute('data-day');
                        data.missedHours[day] = input.value;
                    });

                    document.querySelectorAll('.reason-select').forEach(select => {
                        const day = select.getAttribute('data-day');
                        data.missedReasons[day] = select.value;
                    });

                    localStorage.setItem(`teacherTimesheet_${year}_${month}`, JSON.stringify(data));
                }

                // Načte data z localStorage
                function loadMonthData(month, year) {
                    const savedData = localStorage.getItem(`teacherTimesheet_${year}_${month}`);
                    if (savedData) {
                        return JSON.parse(savedData);
                    }
                    return {
                        substituteHours: {},
                        missedHours: {},
                        missedReasons: {}
                    };
                }

                // Načte data při změně měsíce/roku
                function loadDataFromLocal() {
                    const month = currentMonth;
                    const year = currentYear;

                    const data = loadMonthData(month, year);

                    setTimeout(() => {
                        document.querySelectorAll('.substitute-input').forEach(input => {
                            const day = input.getAttribute('data-day');
                            if (data.substituteHours && data.substituteHours[day]) {
                                input.value = data.substituteHours[day];
                            }
                        });

                        document.querySelectorAll('.missed-input').forEach(input => {
                            const day = input.getAttribute('data-day');
                            if (data.missedHours && data.missedHours[day]) {
                                input.value = data.missedHours[day];
                            }
                        });

                        document.querySelectorAll('.reason-select').forEach(select => {
                            const day = select.getAttribute('data-day');
                            if (data.missedReasons && data.missedReasons[day]) {
                                select.value = data.missedReasons[day];
                            }
                        });

                        updateTotals();
                    }, 100);
                }

                //DASLI SCRIPTY


            </script>
    </body>

</html>