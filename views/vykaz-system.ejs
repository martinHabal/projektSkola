                });

                // Vygeneruje kalendář
                //HLAVNI GROW - TADY SE GENERUJE TABULKA
                function generateCalendar(month, year) {
                    const container = document.getElementById("calendar-container");
                    //vytvori pocet dnu v mesici, ktery se pak pouzije v cyklu
                    //vrátí počet dní v měsíci.
                    const daysInMonth = new Date(year, month + 1, 0).getDate();
                    //vytvori zahlavi
                    let html = `
                <table id="workTable">
                    <thead>
                        <tr>
                            <th>Datum</th>
                            <th>Den</th>
                            <th>Typ dne</th>
                            <th>Odpracované hodiny</th>
                            <th>Suplované hodiny</th>
                            <th>Neodučené hodiny</th>
                            <th>Důvod neodučení</th>
                        </tr>
                    </thead>
                    <tbody>
            `;
                    //tohle nacita data z localstorage, ale toho se musim zbavit
                    const savedData = loadMonthData(month, year);

                    //pro kazdy den v mesici generuje radku v tabulce
                    for (let day = 1; day <= daysInMonth; day++) {
                        const date = new Date(year, month, day); //datum
                        const dayOfWeek = date.getDay(); //den
                        const isWeekend = dayOfWeek === 0 || dayOfWeek === 6; //typ dne
                        const isToday = isSameDay(date, new Date()); //kontroluje, jestli je to dnesni datum -> oznaci asi aktualni den
                        const holidayInfo = getHolidayInfo(day, month, date); //informace o svátcích
                        const isHoliday = holidayInfo !== null; //kontrola svatku
                       

                        let dayType = "Pracovní den";
                        let cssClass = "workday";

                        //nastavujeme tridu pro csska, nastacuje se trida v generovani rádku níže
                        if (isWeekend) ((cssClass = "weekend"), (dayType = "Víkend"));
                        if (isHoliday) ((cssClass = "holiday"), (dayType = "Státní svátek"));
                      

                        const dayNames = [
                            "Neděle",
                            "Pondělí",
                            "Úterý",
                            "Středa",
                            "Čtvrtek",
                            "Pátek",
                            "Sobota",
                        ];
                       

                        const savedSubstitute =
                            savedData.substituteHours && savedData.substituteHours[day]
                                ? savedData.substituteHours[day]
                                : "";
                        const savedMissed =
                            savedData.missedHours && savedData.missedHours[day]
                                ? savedData.missedHours[day]
                                : "";
                        const savedReason =
                            savedData.missedReasons && savedData.missedReasons[day]
                                ? savedData.missedReasons[day]
                                : "";

                       

                        //option s důvody pro neoducené hodiny, to zatim v DB mit nepotrebuju
                        let reasonOptions = '<option value="">-- vyberte --</option>';
                        missedReasons.forEach((reason) => {
                            const selected = savedReason === reason.id ? "selected" : "";
                            reasonOptions += `<option value="${reason.id}" ${selected}>${reason.name}</option>`;
                        });

                        let reasonHintHtml = "";
                       

                        html += `
                    <tr class="${cssClass} ${isToday ? "today" : ""}">
                        <td class="day-header">${day}. ${month + 1}. ${year}</td>
                        <td>${dayNames[dayOfWeek]}</td>
                        <td>${dayType}</td>
                        <td><span class="hours-display">${workHours}</span></td>
                        <td>
                            ${canHaveSubstitute
                                ? `<input type="number" min="0" max="24" value="${savedSubstitute}" class="substitute-input" data-day="${day}">`
                                : `<span>-</span>`
                            }
                        </td>
                      
                    </tr>
                `;
                    }

                    html += `
                    <tr class="total-row">
                        <td colspan="3"><strong>CELKEM</strong></td>
                        <td><strong id="table-total-hours">0</strong></td>
                        <td><strong id="table-total-substitute">0</strong></td>
                        <td><strong id="table-total-missed">0</strong></td>
                        <td></td>
                    </tr>
                </tbody>
            </table>
            `;

                    container.innerHTML = html;
                    addEventListeners();
                    updateTotals();
                    loadDataFromLocal();
                }

                // Přidá event listeners
                function addEventListeners() {
                    document.addEventListener("input", function (e) {
                        if (
                            e.target.classList.contains("substitute-input") ||
                            e.target.classList.contains("missed-input") ||
                            e.target.classList.contains("reason-select")
                        ) {
                            updateTotals();
                            // saveDataToLocal();
                        }
                    });
                }

                // Kontrola stejného dne
                function isSameDay(date1, date2) {
                    return (
                        date1.getDate() === date2.getDate() &&
                        date1.getMonth() === date2.getMonth() &&
                        date1.getFullYear() === date2.getFullYear()
                    );
                }

                // Zjistí svátek
                function getHolidayInfo(day, month, date) {
                    for (const holiday of fixedHolidays) {
                        if (holiday.day === day - 1 && holiday.month === month) {
                            return holiday;
                        }
                    }

                    // if (isEasterHoliday(date)) {
                    //     return { name: "Velikonoční pondělí" };
                    // }

                    return null;
                }


                // Aktualizuje součty
                function updateTotals() {
                    const workHourDisplays = document.querySelectorAll(".hours-display");
                    const substituteInputs = document.querySelectorAll(".substitute-input");
                    const missedInputs = document.querySelectorAll(".missed-input");

                    let totalWorkHours = 0;
                    let totalSubstituteHours = 0;
                    let totalMissedHours = 0;

                    workHourDisplays.forEach((display) => {
                        totalWorkHours += parseFloat(display.textContent) || 0;
                    });

                    substituteInputs.forEach((input) => {
                        totalSubstituteHours += parseFloat(input.value) || 0;
                    });

                    missedInputs.forEach((input) => {
                        totalMissedHours += parseFloat(input.value) || 0;
                    });

                    // Aktualizace tabulkových součtů
                    document.getElementById("table-total-hours").textContent =
                        totalWorkHours;
                    document.getElementById("table-total-substitute").textContent =
                        totalSubstituteHours;
                    document.getElementById("table-total-missed").textContent =
                        totalMissedHours;

                    // Výpočet dalších statistik
                    const totalAllHours = totalWorkHours + totalSubstituteHours;

                    // Aktualizace souhrnu v pravém sloupci
                    document.getElementById("preview-total-hours").textContent =
                        totalWorkHours;
                    document.getElementById("preview-total-substitute").textContent =
                        totalSubstituteHours;
                    document.getElementById("preview-total-missed").textContent =
                        totalMissedHours;
                    document.getElementById("preview-total-all").textContent =
                        totalAllHours;

                    // Aktualizace náhledu
                    updateMissedSummary();
                }

                // Aktualizuje souhrn neoducených hodin
                function updateMissedSummary() {
                    const missedInputs = document.querySelectorAll(".missed-input");
                    let missedDays = [];

                    missedInputs.forEach((input) => {
                        const value = parseFloat(input.value) || 0;
                        if (value > 0) {
                            const day = input.getAttribute("data-day");
                            const row = input.closest("tr");
                            const dateCell = row.querySelector(".day-header");
                            const dateText = dateCell.textContent;
                            const reasonSelect = document.querySelector(
                                `.reason-select[data-day="${day}"]`,
                            );
                            let reasonName = "Neznámý důvod";

                            if (reasonSelect && reasonSelect.value) {
                                const reasonId = reasonSelect.value;
                                const reason = missedReasons.find((r) => r.id === reasonId);
                                if (reason) reasonName = reason.name;
                            }

                            missedDays.push({
                                dateText: dateText,
                                hours: value,
                                reason: reasonName,
                            });
                        }
                    });

                    const previewContainer = document.getElementById("preview-content");

                    if (missedDays.length === 0) {
                        previewContainer.innerHTML =
                            '<div class="no-missed-days">Žádné neoducené hodiny nebyly zaznamenány</div>';
                    } else {
                        let previewHtml = "";
                        let totalMissed = 0;

                        // Seřadit dny podle data
                        missedDays.sort((a, b) => {
                            const aDay = parseInt(a.dateText.split(".")[0]);
                            const bDay = parseInt(b.dateText.split(".")[0]);
                            return aDay - bDay;
                        });

                        // Omezit počet zobrazených dnů v náhledu pro přehlednost
                        const displayDays = missedDays.slice(0, 8);

                        displayDays.forEach((day) => {
                            previewHtml += `
                        <div class="preview-item">
                            <div class="preview-date">${day.dateText}</div>
                            <div class="preview-hours">${day.hours} hodin</div>
                            <div class="preview-reason">${day.reason}</div>
                        </div>
                    `;

                            totalMissed += day.hours;
                        });

                        // Pokud je více dnů než 8, přidat informaci
                        if (missedDays.length > 8) {
                            previewHtml += `
                        <div class="more-days">
                            + dalších ${missedDays.length - 8} dnů
                        </div>
                    `;
                        }

                        // Přidat celkový součet
                        previewHtml += `
                    <div class="preview-total">
                        <div class="preview-total-label">Celkem neoducených hodin:</div>
                        <div class="preview-total-value">${totalMissed} hodin</div>
                    </div>
                `;

                        previewContainer.innerHTML = previewHtml;
                    }
                }

                // Načte data z localStorage
                function loadMonthData(month, year) {
                    const savedData = localStorage.getItem(
                        `teacherTimesheet_${year}_${month}`,
                    );
                    if (savedData) {
                        return JSON.parse(savedData);
                    }
                    return {
                        substituteHours: {},
                        missedHours: {},
                        missedReasons: {},
                    };
                }

                // Načte data při změně měsíce/roku
                function loadDataFromLocal() {
                    const month = currentMonth;
                    const year = currentYear;

                    const data = loadMonthData(month, year);

                    setTimeout(() => {
                        document.querySelectorAll(".substitute-input").forEach((input) => {
                            const day = input.getAttribute("data-day");
                            if (data.substituteHours && data.substituteHours[day]) {
                                input.value = data.substituteHours[day];
                            }
                        });

                        document.querySelectorAll(".missed-input").forEach((input) => {
                            const day = input.getAttribute("data-day");
                            if (data.missedHours && data.missedHours[day]) {
                                input.value = data.missedHours[day];
                            }
                        });

                        document.querySelectorAll(".reason-select").forEach((select) => {
                            const day = select.getAttribute("data-day");
                            if (data.missedReasons && data.missedReasons[day]) {
                                select.value = data.missedReasons[day];
                            }
                        });

                        updateTotals();
                    }, 100);
                }

