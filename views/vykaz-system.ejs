                    5: 8, // Pátek
                    0: 0, // Neděle
                    6: 0  // Sobota
                };

                // Načtení rozvrhu z localStorage
                function loadScheduleFromStorage() {
                    const savedSchedule = localStorage.getItem('teacherSchedule');
                    if (savedSchedule) {
                        return JSON.parse(savedSchedule);
                    }
                    return defaultSchedule;
                }

                // Uložení rozvrhu do localStorage
                function saveScheduleToStorage(schedule) {
                    localStorage.setItem('teacherSchedule', JSON.stringify(schedule));
