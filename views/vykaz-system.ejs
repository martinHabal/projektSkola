                    top: 0;
                    width: 100%;
                    height: 100%;
                    background-color: rgba(0, 0, 0, 0.5);

                    justify-content: center;
                    align-items: center;
                }

                /* Okno modalu */
                .modal-content {
                    position: relative;
                    width: 90%;
                    height: 90%;
                    background: white;
                    border-radius: 10px;
                    overflow: hidden;
