                function parseHolidays(apiData) {
                    return apiData.map((item) => {
                        // Parsování data
                        const date = new Date(item.date);
                        const day = date.getDate();
                        const month = date.getMonth(); // 0 = leden

                        // Získání českého názvu
                        let name = item.localName || item.name;

                        // Speciální případ pro Nový rok - oddělíme část za středníkem
                        if (name.includes(";")) {
                            // Vezmeme část za středníkem a ořízneme mezery
                            const parts = name.split(";");
                            name = parts[parts.length - 1].trim();
                        }

                        return {
                            day: day,
                            month: month,
                            name: name,
                        };
                    });
                }

