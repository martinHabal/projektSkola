<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <h1>Dashboard</h1>
        <p>Vítejte, <strong><%= username %></strong>!</p>
        <p>Vaše role: <strong><%= role %></strong></p>
        <% if (role === 'admin') { %>
            <p><a href="/admin">Správa uživatelů</a></p>
        <% } %>
        <p><a href="/logout">Odhlásit se</a></p>
    </div>
</body>
</html>