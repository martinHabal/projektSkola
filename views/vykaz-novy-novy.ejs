                <script type="module">
                    import { NumberInputHandler } from "./class/UvazkyInputHandler.js";

                    // Odesilani hodin vykazu
                    // samozrejme to musim zkulturnit, ale prozatim tohle funguje
                    // musim ale poresit nacitani, protoze to minule bylo pres sablonu

                    document.addEventListener("DOMContentLoaded", function () {
                        const config = {
                            minValue: 0,
                            maxValue: 100,
                            debounceDelay: 300,
                            endpoint: "/api/process-number",
                            method: "POST",
