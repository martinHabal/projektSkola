                </script>
                <script src="/js/duvody.js"></script>
                <script src="/js/prazdniny.js"></script>
                <script>

                    // Aktuální datum
                    const currentDate = new Date();
                    let currentMonth = currentDate.getMonth();
                    let currentYear = currentDate.getFullYear();

                    
                    //Async/Await je syntaktický cukr nad Promisemi, který dělá asynchronní kód čitelnější - vypadá jako synchronní, ale chová se asynchronně.
                    // async označí funkci jako asynchronní, vzdy vrati promise
                    // await pozastaví vykonávání funkce, dokud Promise není vyřešen (resolved) nebo odmítnut (rejected).
                    async function loadScheduleFromApi() {
                        try {
                            const response = await fetch('http://localhost:3000/api/uvazky');

                            if (!response.ok) {
                                throw new Error(`HTTP error: ${response.status}`);
                            }
                            // await - funkce se pozastaví - - čeká na odpověď serveru. Po dokončení pokračuje
                            const apiData = await response.json();

                            return {
                                1: apiData.po || 0,
                                2: apiData.ut || 0,
                                3: apiData.st || 0,
                                4: apiData.ct || 0,
                                5: apiData.pa || 0
                            };
                        } catch (error) {
                            console.error('Nepodařilo se načíst data:', error.message);
                            return null;
                        }
                    }


                    // Důvody pro neoducené hodiny s nápovědou, načteno z duvody.js
                    const missedReasons = duvodyNepritomnosti()

                    // Školní prázdniny
                    const schoolVacations = skolniPrazdniny()

                    //nacte svatky pres API
                    const dataPromise = (async () => {
                        try {
                            const res = await fetch(
                                "https://date.nager.at/api/v3/PublicHolidays/2026/CZ",
                            );
                            const data = await res.json();
                            return data.map(({ date, localName }) => ({
                                day: new Date(date).getDate(),
                                month: new Date(date).getMonth(),
                                name: localName.split(";").pop().trim(),
                            }));
                        } catch (error) {
                            console.error("Chyba při načítání dat:", error);
                            return []; // Vrátíme prázdné pole v případě chyby
                        }
                    })();

let currentSchedule = {}; //musi byt globalni mimo funkci, pro generateCalendar
                    // Inicializace
                    document.addEventListener("DOMContentLoaded", async function () {

                        // vezme uvazky z inputů a propíše do rozvrhu, vola se po změně inputu -> tohle by slo dát do asynchronni funkce
                        // tohle je pro update, takze se to nenacita hned, tedy tady nevadi kdyz se to bude nacitat async
                        // takze tohle funguje s asynchronni funkci, aktualizujou se veschny hodnoty
                        function updateSchedule() {
                            currentSchedule = {
                                0: 0,
                                1: parseFloat(document.getElementById("schedule-mon").value) || 0,
                                2: parseFloat(document.getElementById("schedule-tue").value) || 0,
                                3: parseFloat(document.getElementById("schedule-wed").value) || 0,
                                4: parseFloat(document.getElementById("schedule-thu").value) || 0,
                                5: parseFloat(document.getElementById("schedule-fri").value) || 0,
                                6: 0,
                            };
                            updateTotals();
                        }

                        const defaultSchedule = await loadScheduleFromApi();
                        console.log('Rozvrh:', defaultSchedule);

                        // Aktuální rozvrh, vytvoří kopii původního objektu
                        currentSchedule = { ...defaultSchedule };

console.log('Rozvrh:', currentSchedule);
                        fixedHolidays = await dataPromise;
                        // Zde už máte data k dispozici
                        // console.log("Data načtena před DOM:", fixedHolidays);


                        initMonthSelector();
                        generateCalendar(currentMonth, currentYear);
                        // loadScheduleToUI();

                        // Nastavit checkbox jako unchecked defaultně
                        document.getElementById("confirm-correctness").checked = false;

                        // Tlačítka jsou disabled defaultně
                        document.getElementById("btn-print").disabled = true;
                        document.getElementById("btn-save").disabled = true;

                        // Event listener pro změnu měsíce
                        document.getElementById("month").addEventListener("change", function () {
                            const month = parseInt(document.getElementById("month").value);
                            currentMonth = month;
                            generateCalendar(month, currentYear);
                        });
                        // Event listener pro checkbox - unchecked defaultně
                        document.getElementById("confirm-correctness").addEventListener("change", function () {
                            const isChecked = this.checked;
                            document.getElementById("btn-print").disabled = !isChecked;
                            document.getElementById("btn-save").disabled = !isChecked;
                        });
                        // Event listenery pro změnu rozvrhu -> toto aktualizuje změnu uvazku v rozvrhu
                        document.querySelectorAll(".day-schedule-input").forEach((input) => {
                            input.addEventListener("change", function () {
//update celkových hodin 
                                  let total = 0;
        document.querySelectorAll(".day-schedule-input").forEach((inp) => {
            const value = parseFloat(inp.value) || 0;
            total += value;
        });
        
        document.getElementById("total-value").textContent = total;

                                updateSchedule();
                                generateCalendar(currentMonth, currentYear);
                            });
                        });

                    });

                    // Inicializuje výběr měsíce
                    function initMonthSelector() {
                        const monthSelect = document.getElementById("month");
                        monthSelect.value = currentMonth;
                    }



                    // Vygeneruje kalendář
                    function generateCalendar(month, year) {
                        // console.log("vykaz se generuje a je znam " + currentSchedule )
                        const container = document.getElementById("calendar-container");
                        const daysInMonth = new Date(year, month + 1, 0).getDate();

                        let html = `
                         <table id="workTable">
                            <thead>
                                <tr>
                                    <th>Datum</th>
                                    <th>Den</th>
                                    <th>Typ dne</th>
                                    <th>Odpracované hodiny</th>
                                    <th>Suplované hodiny</th>
                                    <th>Neodučené hodiny</th>
                                    <th>Důvod neoducení</th>
                                </tr>
                            </thead>
                            <tbody>
                    `;

                        for (let day = 1; day <= daysInMonth; day++) {
                            const date = new Date(year, month, day);
                            const dayOfWeek = date.getDay();
                            const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;//pouze kontroluje víkend kvuli css
                            const isToday = isSameDay(date, new Date());
                            const holidayInfo = getHolidayInfo(day, month, date);
                            const isHoliday = holidayInfo !== null;
                            const vacationInfo = isSchoolVacation(date);
                            const isVacation = vacationInfo !== null;

                            let dayType = "Pracovní den";
                            let cssClass = "workday";//jen nastavuje css

                            if (isWeekend) ((cssClass = "weekend"), (dayType = "Víkend"));//jen css
                            if (isHoliday) ((cssClass = "holiday"), (dayType = "Státní svátek"));//jen css
                            if (isVacation) ((cssClass = "vacation"), (dayType = vacationInfo));//jen css

                            const dayNames = [
                                "Neděle",
                                "Pondělí",
                                "Úterý",
                                "Středa",
                                "Čtvrtek",
                                "Pátek",
                                "Sobota",
                            ];

                            //tady v tom cyklu se asi nastavuje hodina pracovniho dne
                            //pokud je pracovní den, tak vrací odpracovane hodiny, v pripade opacnem nulu
                            //pouziva se poze v generovani tabulky
                            const workHours = !isWeekend && !isHoliday && !isVacation ? currentSchedule[dayOfWeek] || 0 : 0;

                            const canHaveSubstitute = !isWeekend && !isHoliday && !isVacation;//kdy je mozno nastavit supl
                            const canHaveMissed = !isWeekend && !isHoliday && !isVacation;//kdy je mozno nastavit odpadnute

                            let reasonOptions = '<option value="">-- vyberte --</option>';//jen naplní důvody absence
                            missedReasons.forEach((reason) => {
                                reasonOptions += `<option value="${reason.id}">${reason.name}</option>`;
                            });

                            let reasonHintHtml = "";
                            if (canHaveMissed) {//nápověda k odpadnutým
                                reasonHintHtml = `
                                <div class="reason-select-wrapper">
                                    <select class="reason-select" data-day="${day}">
                                        ${reasonOptions}
                                    </select>
                                    <div class="reason-hint">
                                        <span class="hint-icon">?</span>
                                        <div class="hint-text">
                                            <strong>Nápověda k důvodům:</strong><br>
                                            ${missedReasons
                                        .map(
                                            (reason) =>
                                                `<strong>${reason.name}:</strong> ${reason.hint}<br>`,
                                        )
                                        .join("")}
                                        </div>
                                    </div>
                                </div>
                            `;
                            }
                            //tady je generování tabulky
                            html += `
                            <tr class="${cssClass} ${isToday ? "today" : ""}">
                                <td class="day-header">${day}. ${month + 1}. ${year}</td>
                                <td>${dayNames[dayOfWeek]}</td>
                                <td>${dayType}</td>
                                <td><span class="hours-display">${workHours}</span></td>
                                <td>
                                    ${canHaveSubstitute
                                    ? `<input type="number" min="1" max="10" value="" class="substitute-input" data-day="${day}">`
                                    : `<span>-</span>`
                                }
                                </td>
                                <td>
                                    ${canHaveMissed
                                    ? `<input type="number" min="1" max="10" value="" class="missed-input" data-day="${day}">`
                                    : `<span>-</span>`
                                }
                                </td>
                                <td>
                                    ${canHaveMissed ? reasonHintHtml : `<span>-</span>`}
                                </td>
                            </tr>
                        `;
                        }
                        //posledni radek dole
                        html += `
                            <tr class="total-row">
                                <td colspan="3"><strong>CELKEM</strong></td>
                                <td><strong id="table-total-hours">0</strong></td>
                                <td><strong id="table-total-substitute">0</strong></td>
                                <td><strong id="table-total-missed">0</strong></td>
                                <td></td>
                            </tr>
                        </tbody>
                    </table>
                    `;

                        container.innerHTML = html;
                        addEventListeners();
                        updateTotals();
                    }

                    // Přidá event listeners
                    function addEventListeners() {
                        document.removeEventListener("input", handleInputChange);//odebere nevim proc
                        document.addEventListener("input", handleInputChange);//prida na inputy
                    }

                    function handleInputChange(e) {//prida listener na inputy suplovane, odpadnute a duvod, na tech zavola update hodin v tabulce
                        if (
                            e.target.classList.contains("substitute-input") ||
                            e.target.classList.contains("missed-input") ||
                            e.target.classList.contains("reason-select")
                        ) {
                            updateTotals();
                        }
                    }

                    // Kontrola stejného dne -> nevim k cemu to je
                    function isSameDay(date1, date2) {
                        return (
                            date1.getDate() === date2.getDate() &&
                            date1.getMonth() === date2.getMonth() &&
                            date1.getFullYear() === date2.getFullYear()
                        );
                    }

                    // Zjistí svátek
                    function getHolidayInfo(day, month, date) {
                        for (const holiday of fixedHolidays) {//nacita svatky z toho ciziho api
                            if (holiday.day === day && holiday.month === month) {
                                return holiday;
                            }
                        }

                        if (isEasterHoliday(date)) {
                            return { name: "Velikonoční pondělí" };
                        }

                        return null;
                    }

                    // Velikonoční svátek
                    function isEasterHoliday(date) {
                        const year = date.getFullYear();
                        const a = year % 19;
                        const b = Math.floor(year / 100);
                        const c = year % 100;
                        const d = Math.floor(b / 4);
                        const e = b % 4;
                        const f = Math.floor((b + 8) / 25);
                        const g = Math.floor((b - f + 1) / 3);
                        const h = (19 * a + b - d - g + 15) % 30;
                        const i = Math.floor(c / 4);
                        const k = c % 4;
                        const l = (32 + 2 * e + 2 * i - h - k) % 7;
                        const m = Math.floor((a + 11 * h + 22 * l) / 451);
                        const easterMonth = Math.floor((h + l - 7 * m + 114) / 31) - 1;
                        const easterDay = ((h + l - 7 * m + 114) % 31) + 1;

                        const easterMonday = new Date(year, easterMonth, easterDay + 1);
                        return isSameDay(date, easterMonday);
                    }

                    // Školní prázdniny
                    function isSchoolVacation(date) {
                        const year = date.getFullYear();
                        const month = date.getMonth();
                        const day = date.getDate();

                        for (const vacation of schoolVacations) {
                            let fromYear = year;
                            let toYear = year;

                            if (vacation.fromMonth > vacation.toMonth) {
                                if (month >= vacation.fromMonth) {
                                    toYear = year + 1;
                                } else if (month <= vacation.toMonth) {
                                    fromYear = year - 1;
                                }
                            }

                            const fromDate = new Date(
                                fromYear,
                                vacation.fromMonth,
                                vacation.fromDay,
                            );
                            const toDate = new Date(toYear, vacation.toMonth, vacation.toDay);

                            if (date >= fromDate && date <= toDate) {
                                return vacation.name;
                            }
                        }

                        return null;
                    }

                    // Aktualizuje součty
                    function updateTotals() {
                        const workHourDisplays = document.querySelectorAll(".hours-display");//odpracovane uvazky v tabulce
                        const substituteInputs = document.querySelectorAll(".substitute-input");//suplovane
                        const missedInputs = document.querySelectorAll(".missed-input");//neoducene

                        let totalWorkHours = 0;
                        let totalSubstituteHours = 0;
                        let totalMissedHours = 0;

                        workHourDisplays.forEach((display) => {
                            totalWorkHours += parseFloat(display.textContent) || 0;
                        });

                        substituteInputs.forEach((input) => {
                            totalSubstituteHours += parseFloat(input.value) || 0;
                        });

                        missedInputs.forEach((input) => {
                            totalMissedHours += parseFloat(input.value) || 0;
                        });

                        // Aktualizace tabulkových součtů
                        document.getElementById("table-total-hours").textContent = totalWorkHours;
                        document.getElementById("table-total-substitute").textContent = totalSubstituteHours;
                        document.getElementById("table-total-missed").textContent = totalMissedHours;
                        // uvazek + suplovaný
                        const totalAllHours = totalWorkHours + totalSubstituteHours;
                        // Aktualizace souhrnu v pravém sloupci v SOHRN VYKAZU
                        document.getElementById("preview-total-hours").textContent = totalWorkHours;
                        document.getElementById("preview-total-substitute").textContent = totalSubstituteHours;
                        document.getElementById("preview-total-missed").textContent = totalMissedHours;
                        document.getElementById("preview-total-all").textContent = totalAllHours;

                        // Aktualizace náhledu
                        updateMissedSummary();
                    }

                    // Aktualizuje souhrn neodučených hodin v pravem sloupci
                    function updateMissedSummary() {
                        const missedInputs = document.querySelectorAll(".missed-input");
                        let missedDays = [];

                        missedInputs.forEach((input) => {
                            const value = parseFloat(input.value) || 0;
                            if (value > 0) {
                                const day = input.getAttribute("data-day");
                                const row = input.closest("tr");
                                const dateCell = row.querySelector(".day-header");
                                const dateText = dateCell.textContent;
                                const reasonSelect = document.querySelector(
                                    `.reason-select[data-day="${day}"]`,
                                );
                                let reasonName = "Neznámý důvod";

                                if (reasonSelect && reasonSelect.value) {
                                    const reasonId = reasonSelect.value;
                                    const reason = missedReasons.find((r) => r.id === reasonId);
                                    if (reason) reasonName = reason.name;
                                }

                                missedDays.push({
                                    dateText: dateText,
                                    hours: value,
                                    reason: reasonName,
                                });
                            }
                        });

                        const previewContainer = document.getElementById("preview-content");

                        if (missedDays.length === 0) {
                            previewContainer.innerHTML =
                                '<div class="no-missed-days">Žádné neoducené hodiny nebyly zaznamenány</div>';
                        } else {
                            let previewHtml = "";
                            let totalMissed = 0;

                            // Seřadit dny podle data
                            missedDays.sort((a, b) => {
                                const aDay = parseInt(a.dateText.split(".")[0]);
                                const bDay = parseInt(b.dateText.split(".")[0]);
                                return aDay - bDay;
                            });

                            // Omezit počet zobrazených dnů v náhledu pro přehlednost
                            const displayDays = missedDays.slice(0, 8);

                            displayDays.forEach((day) => {
                                previewHtml += `
                                <div class="preview-item">
                                    <div class="preview-date">${day.dateText}</div>
                                    <div class="preview-hours">${day.hours} hodin</div>
                                    <div class="preview-reason">${day.reason}</div>
                                </div>
                            `;

                                totalMissed += day.hours;
                            });

                            // Pokud je více dnů než 8, přidat informaci
                            if (missedDays.length > 8) {
                                previewHtml += `
                                <div class="more-days">
                                    + dalších ${missedDays.length - 8} dnů
                                </div>
                            `;
                            }

                            // Přidat celkový součet
                            previewHtml += `
                            <div class="preview-total">
                                <div class="preview-total-label">Celkem neodučených hodin:</div>
                                <div class="preview-total-value">${totalMissed} hodin</div>
                            </div>
                        `;

                            previewContainer.innerHTML = previewHtml;
                        }
                    }

                    //ULOZENI VYKAZU START
                    // Event listener pro tlačítko ulozit
                    document.getElementById("btn-save").addEventListener("click", function () {
                        // Funkce pro získání dat z tabulky
                        function tableToObjectArray(tableId) {
                            // Získáme tabulku podle ID
                            const table = document.getElementById(tableId);
                            if (!table) {
                                console.error("Tabulka s tímto ID nebyla nalezena.");
                                return [];
                            }

                            // Získáme všechny řádky tabulky (kromě hlavičky)
                            const rows = table.querySelectorAll("tbody tr");
                            const result = [];

                            // Získáme názvy sloupců z hlavičky
                            const headers = [];
                            const headerCells = table.querySelectorAll("thead th");
                            headerCells.forEach((th) => {
                                headers.push(th.textContent.trim());
                            });

                            // Pro každý řádek vytvoříme objekt
                            rows.forEach((row) => {
                                const cells = row.querySelectorAll("td");
                                const obj = {};

                                // Pro každou buňku v řádku přiřadíme hodnotu k příslušnému klíči
                                cells.forEach((cell, index) => {
                                    if (index < headers.length) {
                                        const key = headers[index];
                                        let value;

                                        // Zkontrolujeme, zda buňka obsahuje input nebo select prvek
                                        const input = cell.querySelector("input");
                                        const select = cell.querySelector("select");

                                        if (input) {
                                            // Zpracování input prvků
                                            value = input.value.trim();

                                            if (input.type === "checkbox") {
                                                value = input.checked;
                                            } else if (input.type === "number") {
                                                const numValue = parseFloat(value);
                                                if (!isNaN(numValue)) {
                                                    value = numValue;
                                                }
                                            }
                                        } else if (select) {
                                            // Zpracování select prvků - načteme aktuálně vybranou hodnotu
                                            value = select.value;

                                            // Pokud je select multiple, vrátíme pole vybraných hodnot
                                            if (select.multiple) {
                                                value = Array.from(select.selectedOptions).map(
                                                    (option) => option.value,
                                                );
                                            }

                                            // Pokusíme se převést na číslo, pokud je to možné
                                            if (typeof value === "string" && value !== "") {
                                                const cleanValue = value
                                                    .replace(/\s/g, "")
                                                    .replace(/,/g, ".");
                                                if (!isNaN(cleanValue) && cleanValue !== "") {
                                                    value = parseFloat(cleanValue);
                                                }
                                            }
                                        } else {
                                            // Pokud žádný prvek neexistuje, vezmeme textový obsah buňky
                                            value = cell.textContent.trim();

                                            // Pokusíme se převést číselné hodnoty
                                            if (value !== "") {
                                                const cleanValue = value
                                                    .replace(/\s/g, "")
                                                    .replace(/,/g, ".");
                                                if (!isNaN(cleanValue) && cleanValue !== "") {
                                                    value = parseFloat(cleanValue);
                                                }
                                            }
                                        }

                                        obj[key] = value;
                                    }
                                });

                                result.push(obj);
                            });

                            return result;
                        }

                        const data = tableToObjectArray("workTable");
                        // console.log(data);

                        fetch(`/api/uloz-vykaz`, {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                            },
                            body: JSON.stringify({
                                data: data,
                            }),
                        });

                        // POUZE RESI ZDA JE VYKAZ ODEVZADNEJ
                        //toto nyní ted funguje
                        async function odevzdatVykaz() {
                            try {
                                const response = await fetch(`/api/odevzdano`, {
                                    method: "POST",
                                    headers: {
                                        "Content-Type": "application/json",
                                    },
                                    // Pokud neposíláš žádná data, nemusíš posílat body
                                    // body: JSON.stringify({ data: data }),
                                });

                                const result = await response.json();
                                // console.log('Odpověď z backendu:', result);

                                if (result.success) {
                                    if (result.ulozeno) {
                                        alert('✅ ' + result.message);
                                        location.reload();
                                      
                                    } else {
                                        alert('ℹ️ ' + result.message);
                                    }
                                } else {
                                    alert('❌ ' + result.message);
                                }

                            } catch (error) {
                                console.error('Chyba při odesílání:', error);
                                alert('❌ Nepodařilo se připojit k serveru. Zkontroluj připojení.');
                            }
                        }

                        // Zavolání funkce
                        odevzdatVykaz();
                    });

                    //!ULOZENI VYKAZU END

                    // Funkce pro smazání posledního záznamu
                    // 
                    async function deleteLastRecord() {
                        try {
                            const response = await fetch(`/api/record/last`, {
                                method: 'GET', // Změněno z GET na DELETE
                                headers: {
                                    'Content-Type': 'application/json'
                                },
                                credentials: 'include' // DŮLEŽITÉ pro session cookies
                            });

                            const data = await response.json();

                            // if (!response.ok) {
                            //     throw new Error(data.message || 'Chyba při mazání');
                            // }

                            // Kontrola, zda bylo smazáno
                            if (data.success || data.deleted || data.affectedRows > 0) {
                                // Úspěšné smazání
                                alert('✅ Záznam byl úspěšně smazán!');
                                console.log('Smazáno:', data);
                                location.reload();
                                // Můžeš vrátit i další informace
                                return {
                                    success: true,
                                    data: data,
                                    deleted: true
                                };
                            } else {
                                // Nic nebylo smazáno (např. žádný záznam neexistoval)
                                alert('ℹ️ Žádný záznam nebyl nalezen k smazání.');
                                return {
                                    success: true,
                                    data: data,
                                    deleted: false,
                                    message: 'Žádný záznam k smazání'
                                };
                            }

                        } catch (error) {
                            console.error('Chyba při mazání:', error);

                            // Zobrazení chybového alertu
                            alert('❌ Chyba při mazání: ' + (error.message || 'Neznámá chyba'));

                            return {
                                success: false,
                                error: error.message
                            };
                        }
                    }
                    //TISK
                    // Připraví data pro tisk - vytvoří výstupní tabulku
                    function prepareForPrint() {
                        const month = currentMonth;
                        const year = currentYear;

                        // Aktualizovat datum tisku
                        const now = new Date();
                        document.getElementById("print-date").textContent =
                            `Vytištěno: ${now.toLocaleDateString("cs-CZ")}`;

                        // Aktualizovat záhlaví pro tisk
                        const monthNames = [
                            "Leden",
                            "Únor",
                            "Březen",
                            "Duben",
                            "Květen",
                            "Červen",
                            "Červenec",
                            "Srpen",
                            "Září",
                            "Říjen",
                            "Listopad",
                            "Prosinec",
                        ];
                    

                        // Načíst data z aktuální tabulky
                        const rows = document.querySelectorAll(
                            "#calendar-container tbody tr:not(.total-row)",
                        );
                        const tableBody = document.getElementById("print-table-body");
                        tableBody.innerHTML = "";

                        let totalWorkHours = 0;
                        let totalSubstituteHours = 0;
                        let totalMissedHours = 0;

                        rows.forEach((row) => {
                            const cells = row.cells;
                            const date = cells[0].textContent;
                            const day = cells[1].textContent;
                            const dayType = cells[2].textContent;

                            // Odpracované hodiny
                            const workHours =
                                parseFloat(cells[3].querySelector(".hours-display").textContent) ||
                                0;
                            totalWorkHours += workHours;

                            // Suplované hodiny
                            const substituteInput = cells[4].querySelector(".substitute-input");
                            const substituteHours = substituteInput
                                ? parseFloat(substituteInput.value) || 0
                                : 0;
                            totalSubstituteHours += substituteHours;

                            // Neodučené hodiny
                            const missedInput = cells[5].querySelector(".missed-input");
                            const missedHours = missedInput
                                ? parseFloat(missedInput.value) || 0
                                : 0;
                            totalMissedHours += missedHours;

                            // Důvod
                            const reasonSelect = cells[6].querySelector(".reason-select");
                            let reason = "-";
                            if (reasonSelect && reasonSelect.value) {
                                const reasonId = reasonSelect.value;
                                const reasonObj = missedReasons.find((r) => r.id === reasonId);
                                reason = reasonObj ? reasonObj.name : "-";
                            }

                            // Určit CSS třídu pro typ dne
                            let dayClass = "";
                            if (dayType === "Víkend") dayClass = "print-weekend";
                            else if (dayType === "Státní svátek") dayClass = "print-holiday";
                            else if (dayType.includes("prázdniny")) dayClass = "print-vacation";

                            // Vytvořit řádek pro tisk
                            const tr = document.createElement("tr");
                            if (dayClass) tr.className = dayClass;

                            tr.innerHTML = `
                            <td>${date}</td>
                            <td>${day}</td>
                            <td>${dayType}</td>
                            <td>${workHours}</td>
                            <td>${substituteHours}</td>
                            <td>${missedHours}</td>
                            <td>${reason}</td>
                        `;

                            tableBody.appendChild(tr);
                        });

                        // Přidat součtový řádek
                        const totalRow = document.createElement("tr");
                        totalRow.className = "print-total";
                        totalRow.innerHTML = `
                        <td colspan="3"><strong>CELKEM</strong></td>
                        <td><strong>${totalWorkHours}</strong></td>
                        <td><strong>${totalSubstituteHours}</strong></td>
                        <td><strong>${totalMissedHours}</strong></td>
                        <td></td>
                    `;
                        tableBody.appendChild(totalRow);
                    }

                </script>

