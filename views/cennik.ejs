<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Výkaz práce – ceník služeb</title>
  <!-- Google Fonts pro moderní vzhled -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(145deg, #f6f9fc 0%, #e9f0f5 100%);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 2rem 1.5rem;
    }

    .pricing-wrapper {
      max-width: 1400px;
      width: 100%;
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(2px);
      border-radius: 48px;
      padding: 2.5rem 2rem;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
      transition: all 0.2s ease;
    }

    /* header */
    .header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .header h1 {
      font-size: 2.8rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #0b2b3f;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.3rem 0.8rem;
    }

    .header h1 span {
      background: #1a4b6b;
      color: white;
      font-size: 1.6rem;
      font-weight: 600;
      padding: 0.2rem 1.2rem;
      border-radius: 60px;
      letter-spacing: 0.3px;
    }

    .header p {
      font-size: 1.2rem;
      color: #2c4c66;
      margin-top: 0.6rem;
      font-weight: 400;
      background: rgba(255,255,255,0.5);
      display: inline-block;
      padding: 0.4rem 2rem;
      border-radius: 60px;
      backdrop-filter: blur(4px);
      box-shadow: 0 2px 6px rgba(0,0,0,0.02);
    }

    .currency-note {
      margin-top: 0.3rem;
      font-size: 0.95rem;
      color: #3e5f77;
      background: #dce8f0;
      display: inline-block;
      padding: 0.2rem 1.6rem;
      border-radius: 30px;
      font-weight: 500;
      letter-spacing: 0.2px;
    }

    /* cenová mřížka */
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 2rem;
      margin-top: 1rem;
    }

    /* karta */
    .pricing-card {
      background: #ffffff;
      border-radius: 32px;
      padding: 2rem 1.5rem 2rem;
      box-shadow: 0 12px 30px -8px rgba(10, 35, 55, 0.12);
      transition: all 0.25s ease;
      border: 1px solid rgba(255, 255, 255, 0.5);
      backdrop-filter: blur(2px);
      display: flex;
      flex-direction: column;
      position: relative;
    }

    .pricing-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 28px 40px -14px rgba(8, 48, 78, 0.25);
      border-color: #c0d9e8;
    }

    .card-badge {
      position: absolute;
      top: -12px;
      left: 50%;
      transform: translateX(-50%);
      background: #1f5a7e;
      color: white;
      font-weight: 600;
      font-size: 0.8rem;
      padding: 0.25rem 1.4rem;
      border-radius: 40px;
      letter-spacing: 0.3px;
      text-transform: uppercase;
      box-shadow: 0 4px 8px rgba(0,40,70,0.2);
      white-space: nowrap;
      border: 1px solid rgba(255,255,255,0.2);
    }

    .card-badge.popular {
      background: #d48c2c;
    }

    .plan-name {
      font-size: 1.8rem;
      font-weight: 700;
      color: #0b2b3f;
      margin-top: 0.4rem;
      letter-spacing: -0.02em;
      border-bottom: 3px solid #deecf5;
      padding-bottom: 0.7rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .plan-name small {
      font-size: 0.9rem;
      font-weight: 400;
      color: #3c6b89;
      background: #e4eef7;
      padding: 0.1rem 0.9rem;
      border-radius: 30px;
    }

    .price-block {
      margin: 1.5rem 0 0.8rem;
    }

    .price {
      font-size: 3.2rem;
      font-weight: 700;
      color: #003153;
      letter-spacing: -0.02em;
      line-height: 1;
    }

    .price small {
      font-size: 1.2rem;
      font-weight: 600;
      color: #3d6d8b;
      margin-left: 0.2rem;
    }

    .price-sub {
      font-size: 1rem;
      font-weight: 500;
      color: #2b5b79;
      background: #e1eef9;
      display: inline-block;
      padding: 0.1rem 1.2rem;
      border-radius: 30px;
      margin-top: 0.25rem;
    }

    .price-desc {
      font-size: 0.95rem;
      color: #2a4d66;
      margin: 0.6rem 0 0.9rem;
      font-weight: 500;
      background: #f2f8fe;
      padding: 0.3rem 0.8rem;
      border-radius: 40px;
      display: inline-block;
      align-self: flex-start;
    }

    .feature-list {
      list-style: none;
      margin: 1.2rem 0 1.8rem;
      flex: 1;
    }

    .feature-list li {
      font-size: 1rem;
      color: #1c4057;
      padding: 0.5rem 0 0.5rem 1.9rem;
      background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="%231f5a7e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>') left center no-repeat;
      background-size: 1.2rem;
      border-bottom: 1px solid rgba(0, 48, 73, 0.04);
    }

    .feature-list li:last-child {
      border-bottom: none;
    }

    .btn-detail {
      background: transparent;
      border: 2px solid #1c5779;
      color: #1c5779;
      font-weight: 700;
      font-size: 1rem;
      padding: 0.75rem 1rem;
      border-radius: 60px;
      width: 100%;
      cursor: default;
      transition: 0.15s;
      text-align: center;
      letter-spacing: 0.3px;
      margin-top: 0.3rem;
    }

    .btn-detail.primary {
      background: #1f5a7e;
      border: 2px solid #1f5a7e;
      color: white;
      box-shadow: 0 8px 14px -6px rgba(20, 70, 110, 0.3);
    }

    .btn-detail.primary:hover {
      background: #134669;
      border-color: #134669;
      transform: scale(1.01);
    }

    .btn-detail:hover {
      background: #e2eefb;
    }

    .card-footnote {
      font-size: 0.8rem;
      color: #3e697f;
      text-align: center;
      margin-top: 1rem;
      border-top: 1px dashed #b6cfdf;
      padding-top: 0.9rem;
      opacity: 0.8;
    }

    /* responzivita */
    @media (max-width: 700px) {
      .pricing-wrapper {
        padding: 1.8rem 1rem;
      }
      .header h1 {
        font-size: 2.1rem;
      }
      .header h1 span {
        font-size: 1.2rem;
        padding: 0.1rem 1rem;
      }
      .price {
        font-size: 2.8rem;
      }
      .pricing-grid {
        gap: 1.8rem;
      }
    }

    @media (max-width: 480px) {
      .header h1 {
        font-size: 1.7rem;
        flex-direction: column;
        gap: 0.1rem;
      }
      .header p {
        font-size: 1rem;
        padding: 0.2rem 1.2rem;
      }
      .price {
        font-size: 2.4rem;
      }
    }
  </style>
</head>
<body>
  <div class="pricing-wrapper">
    <div class="header">
      <h1>
        📋 Výkaz práce
        <span>ceník</span>
      </h1>
      <p>Přehledné ceny pro firmy i živnostníky</p>
      <div class="currency-note">💶 všechny ceny v Kč (bez DPH) · platnost od 1. 1. 2026</div>
    </div>

    <div class="pricing-grid">
      <!-- Základní -->
      <div class="pricing-card">
        <div class="card-badge">Start</div>
        <div class="plan-name">
          Základní
          <small>měsíc</small>
        </div>
        <div class="price-block">
          <div class="price">890 <small>Kč</small></div>
          <div class="price-sub">+ DPH</div>
        </div>
        <div class="price-desc">⏱️ 10 výkazů / měsíc</div>
        <ul class="feature-list">
          <li>Evidence času & projektů</li>
          <li>Export do PDF / Excel</li>
          <li>Přehledná tabulka</li>
          <li>E-mailová podpora</li>
        </ul>
        <div class="btn-detail">Vybrat balík</div>
        <div class="card-footnote">✔ ideální pro začínající OSVČ</div>
      </div>

      <!-- Profesionál – populární -->
      <div class="pricing-card">
        <div class="card-badge popular">🔥 nejoblíbenější</div>
        <div class="plan-name">
          Profesionál
          <small>měsíc</small>
        </div>
        <div class="price-block">
          <div class="price">1 690 <small>Kč</small></div>
          <div class="price-sub">+ DPH</div>
        </div>
        <div class="price-desc">📊 neomezené výkazy</div>
        <ul class="feature-list">
          <li>Neomezený počet výkazů</li>
          <li>Automatické připomínky</li>
          <li>Integrace s kalendářem</li>
          <li>API pro vlastní aplikace</li>
          <li>Prioritní podpora</li>
        </ul>
        <div class="btn-detail primary">Vybrat balík</div>
        <div class="card-footnote">⭐ pro týmy a náročné profese</div>
      </div>

      <!-- Týmový -->
      <div class="pricing-card">
        <div class="card-badge">Tým</div>
        <div class="plan-name">
          Týmový
          <small>uživatel / měs.</small>
        </div>
        <div class="price-block">
          <div class="price">1 290 <small>Kč</small></div>
          <div class="price-sub">+ DPH / os.</div>
        </div>
        <div class="price-desc">👥 3–20 uživatelů</div>
        <ul class="feature-list">
          <li>Vše z Profesionál +</li>
          <li>Sdílené projekty</li>
          <li>Role a oprávnění</li>
          <li>Hromadný export</li>
          <li>Dedikovaný správce</li>
        </ul>
        <div class="btn-detail">Vybrat balík</div>
        <div class="card-footnote">📌 cena za každého uživatele</div>
      </div>

      <!-- Enterprise / individuální -->
      <div class="pricing-card">
        <div class="card-badge">Enterprise</div>
        <div class="plan-name">
          Individuální
          <small>na míru</small>
        </div>
        <div class="price-block">
          <div class="price">3 490 <small>Kč</small></div>
          <div class="price-sub">+ DPH / měs.</div>
        </div>
        <div class="price-desc">🏢 od 20+ uživatelů</div>
        <ul class="feature-list">
          <li>Vše z Týmového balíku</li>
          <li>SSO & vlastní doména</li>
          <li>Individuální SLA</li>
          <li>Školení a onboarding</li>
          <li>Custom reporting</li>
        </ul>
        <div class="btn-detail">Kontaktovat</div>
        <div class="card-footnote">🔒 cenová kalkulace na základě požadavků</div>
      </div>
    </div>

    <!-- malá poznámka pod čarou -->
    <div style="margin-top: 2.8rem; text-align: center; font-size: 0.9rem; color: #38657f; border-top: 1px solid #c0d6e5; padding-top: 1.5rem; letter-spacing: 0.2px; display: flex; flex-wrap: wrap; justify-content: center; gap: 0.3rem 1.8rem;">
      <span>🕒 Roční platba = 10 % sleva</span>
      <span>📞 Zákaznická linka: +420 800 123 456</span>
      <span>📧 info@vykazprace.cz</span>
    </div>
  </div>
</body>
</html>