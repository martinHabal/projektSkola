<!DOCTYPE html>
<html lang="cs">

    <style>
        /* * {
            box-sizing: border-box;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f5f7fa;
            color: #333;
            margin: 0;
            padding: 20px;
            line-height: 1.6;
        } */

        .container {
            max-width: 1200px;
            margin: 0 auto;
            background-color: white;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            padding: 25px;
        }

        h1 {
            color: #2c3e50;
            text-align: center;
            margin-bottom: 5px;
            padding-bottom: 10px;
            font-size: clamp(1.5rem, 4vw, 2.2rem);
        }

        .subtitle {
            text-align: center;
            color: #7f8c8d;
            margin-bottom: 25px;
            font-size: clamp(0.9rem, 2vw, 1.1rem);
        }

        .header-line {
            border: none;
            height: 2px;
            background: linear-gradient(to right, transparent, #3498db, transparent);
            margin-bottom: 25px;
        }

        /* Statistiky */
        .stats-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin-bottom: 25px;
        }

        .stat-card {
            background-color: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            text-align: center;
            border-left: 4px solid #3498db;
        }

        .stat-card .stat-number {
            font-size: 2rem;
            font-weight: 700;
            color: #2c3e50;
            display: block;
        }

        .stat-card .stat-label {
            font-size: 0.85rem;
            color: #7f8c8d;
        }

        /* Filtr a vyhledávání */
        .filter-section {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 25px;
            padding: 15px 20px;
            background-color: #f8f9fa;
            border-radius: 8px;
            align-items: center;
        }

        .filter-section label {
            font-weight: 600;
            color: #2c3e50;
            font-size: 0.9rem;
            white-space: nowrap;
        }

        .filter-section select,
        .filter-section input {
            padding: 8px 12px;
            border: 1px solid #bdc3c7;
            border-radius: 5px;
            font-size: 0.95rem;
            background-color: white;
        }

        .filter-section input {
            flex: 1 1 200px;
            min-width: 150px;
        }

        .filter-section select {
            min-width: 150px;
        }

        .filter-clear {
            background-color: #e74c3c;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.9rem;
            transition: background-color 0.3s;
        }

        .filter-clear:hover {
            background-color: #c0392b;
        }

        /* Legenda */
        .legenda {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 25px;
            padding: 15px 20px;
            background-color: #f8f9fa;
            border-left: 4px solid #3498db;
            border-radius: 0 8px 8px 0;
        }

        .legenda-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: clamp(0.8rem, 1.8vw, 0.9rem);
        }

        .color-box {
            width: 20px;
            height: 20px;
            border-radius: 3px;
            border: 1px solid #ddd;
            flex-shrink: 0;
        }

        /* Seznam dokumentů */
        .documents-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin-top: 10px;
        }

        .doc-card {
            background-color: white;
            border: 1px solid #e8e8e8;
            border-radius: 10px;
            padding: 18px 22px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            transition: box-shadow 0.3s, transform 0.2s;
            display: grid;
            grid-template-columns: auto 1fr auto;
            gap: 15px 20px;
            align-items: center;
        }

        .doc-card:hover {
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            transform: translateY(-2px);
        }

        .doc-card .doc-icon {
            font-size: 2rem;
            text-align: center;
            min-width: 50px;
        }

        .doc-card .doc-body {
            flex: 1;
        }

        .doc-card .doc-title {
            font-weight: 600;
            font-size: clamp(1rem, 2vw, 1.15rem);
            color: #2c3e50;
            margin-bottom: 4px;
        }

        .doc-card .doc-description {
            color: #555;
            font-size: clamp(0.85rem, 1.8vw, 0.95rem);
            line-height: 1.5;
            word-break: break-word;
            margin-top: 4px;
        }

        .doc-card .doc-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 8px;
            font-size: 0.85rem;
            color: #7f8c8d;
        }

        .doc-card .doc-meta span {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .doc-card .doc-tag {
            display: inline-block;
            padding: 2px 12px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            white-space: nowrap;
        }

        .doc-tag-official {
            background-color: #e3f2fd;
            color: #1565c0;
        }

        .doc-tag-study {
            background-color: #fff3e0;
            color: #e65100;
        }

        .doc-tag-forms {
            background-color: #fce4ec;
            color: #c62828;
        }

        .doc-tag-schedule {
            background-color: #f3e5f5;
            color: #6a1b9a;
        }

        .doc-tag-other {
            background-color: #e8f5e9;
            color: #2e7d32;
        }

        .doc-card .doc-actions {
            display: flex;
            gap: 8px;
            align-self: flex-start;
            margin-top: 4px;
        }

        .doc-card .doc-actions .btn-download {
            background-color: #3498db;
            color: white;
            border: none;
            padding: 6px 14px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.85rem;
            transition: background-color 0.3s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .doc-card .doc-actions .btn-download:hover {
            background-color: #2980b9;
        }

        .doc-card .doc-actions .btn-preview {
            background-color: #95a5a6;
            color: white;
            border: none;
            padding: 6px 14px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.85rem;
            transition: background-color 0.3s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .doc-card .doc-actions .btn-preview:hover {
            background-color: #7f8c8d;
        }

        /* Stav, když nejsou dokumenty */
        .no-documents {
            text-align: center;
            padding: 50px 20px;
            color: #7f8c8d;
            font-style: italic;
            background-color: #fafafa;
            border-radius: 10px;
            border: 2px dashed #ddd;
        }

        .no-documents .icon {
            font-size: 3rem;
            display: block;
            margin-bottom: 10px;
        }

        /* Počet dokumentů */
        .doc-count {
            text-align: right;
            font-size: 0.9rem;
            color: #7f8c8d;
            margin-bottom: 10px;
        }

        .doc-count strong {
            color: #2c3e50;
        }

        /* Informace o aktualizaci */
        .update-info {
            text-align: center;
            font-size: 0.8rem;
            color: #95a5a6;
            margin-top: 20px;
            padding-top: 15px;
            border-top: 1px solid #eee;
        }

        .update-info .badge {
            display: inline-block;
            background-color: #27ae60;
            color: white;
            padding: 2px 10px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 600;
            margin-left: 8px;
        }

        /* Responzivní úpravy */
        @media (max-width: 768px) {
            .doc-card {
                grid-template-columns: 1fr;
                gap: 8px;
            }

            .doc-card .doc-icon {
                text-align: left;
                font-size: 1.5rem;
                min-width: auto;
            }

            .doc-card .doc-actions {
                align-self: stretch;
                justify-content: flex-start;
                flex-wrap: wrap;
            }

            .filter-section {
                flex-direction: column;
                align-items: stretch;
            }

            .filter-section label {
                white-space: normal;
            }

            .stats-section {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media print {
            .no-print {
                display: none !important;
            }
            .doc-card {
                break-inside: avoid;
                border: 1px solid #ccc;
                box-shadow: none !important;
            }
            .container {
                box-shadow: none !important;
            }
            .stats-section {
                display: none !important;
            }
        }
    </style>

