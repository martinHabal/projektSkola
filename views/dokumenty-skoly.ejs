                    updated: "1.9.2024",
                    downloadUrl: "#",
                    previewUrl: "#"
                },
                {
                    id: 2,
                    title: "Učební plán - IT obor",
                    description: "Podrobný učební plán pro obor Informační technologie. Obsahuje přehled předmětů, hodinových dotací a doporučené literatury.",
                    category: "study",
                    icon: "💻",
                    fileSize: "1.8 MB",
                    updated: "15.8.2024",
                    downloadUrl: "#",
                    previewUrl: "#"
                },
                {
                    id: 3,
                    title: "Přihláška k maturitní zkoušce",
                    description: "Formulář pro přihlášení k maturitní zkoušce. Vyplňte a odevzdejte do 31. ledna 2025.",
                    category: "forms",
                    icon: "📝",
                    fileSize: "0.5 MB",
                    updated: "10.10.2024",
                    downloadUrl: "#",
                    previewUrl: "#"
                },
                {
                    id: 4,
                    title: "Rozvrh hodin - zimní semestr",
                    description: "Aktuální rozvrh hodin pro zimní semestr 2024/2025. Zahrnuje všechny ročníky a obory.",
                    category: "schedule",
                    icon: "📅",
                    fileSize: "3.2 MB",
                    updated: "1.9.2024",
                    downloadUrl: "#",
                    previewUrl: "#"
                },
                {
                    id: 5,
                    title: "Studijní a zkušební řád",
                    description: "Studijní a zkušební řád školy. Upravuje průběh studia, zkoušky, klasifikaci a uznávání předmětů.",
                    category: "official",
                    icon: "⚖️",
                    fileSize: "1.2 MB",
                    updated: "20.8.2024",
                    downloadUrl: "#",
                    previewUrl: "#"
                },
                {
                    id: 6,
                    title: "Materiály k maturitě",
                    description: "Kompletní přehled maturitních témat, seznam literatury a vzorové testy pro všechny předměty.",
                    category: "study",
                    icon: "📚",
                    fileSize: "8.5 MB",
                    updated: "5.10.2024",
                    downloadUrl: "#",
                    previewUrl: "#"
                },
                {
                    id: 7,
                    title: "Žádost o ubytování na koleji",
                    description: "Formulář pro podání žádosti o ubytování na studentské koleji. Termín podání do 31.5.2025.",
                    category: "forms",
                    icon: "🏠",
                    fileSize: "0.3 MB",
                    updated: "1.9.2024",
                    downloadUrl: "#",
                    previewUrl: "#"
                },
                {
                    id: 8,
                    title: "Kalendář akademického roku",
                    description: "Důležité termíny a události akademického roku 2024/2025 - zkoušková období, prázdniny, státní svátky.",
                    category: "schedule",
                    icon: "📆",
                    fileSize: "0.8 MB",
                    updated: "25.8.2024",
                    downloadUrl: "#",
                    previewUrl: "#"
                },
                {
                    id: 9,
                    title: "Etický kodex školy",
                    description: "Etický kodex školy - zásady chování, akademická integrita a pravidla slušného jednání.",
                    category: "official",
                    icon: "🤝",
                    fileSize: "0.6 MB",
                    updated: "1.9.2024",
                    downloadUrl: "#",
                    previewUrl: "#"
                },
                {
                    id: 10,
                    title: "Skripta - Programování v Pythonu",
                    description: "Kompletní učební materiály pro předmět Programování v Pythonu. Obsahuje teoretické základy i praktické příklady.",
                    category: "study",
                    icon: "🐍",
                    fileSize: "12.0 MB",
                    updated: "15.9.2024",
                    downloadUrl: "#",
                    previewUrl: "#"
                },
                {
                    id: 11,
                    title: "Žádost o stipendium",
                    description: "Formulář pro podání žádosti o prospěchové nebo sociální stipendium. Vyplňte a doložte potřebné dokumenty.",
                    category: "forms",
                    icon: "💰",
                    fileSize: "0.4 MB",
                    updated: "1.10.2024",
                    downloadUrl: "#",
                    previewUrl: "#"
                },
                {
                    id: 12,
                    title: "Informace k přijímacímu řízení",
                    description: "Kompletní informace k přijímacímu řízení pro akademický rok 2025/2026 - termíny, požadavky, přihlášky.",
                    category: "official",
                    icon: "📋",
                    fileSize: "1.5 MB",
                    updated: "1.11.2024",
                    downloadUrl: "#",
                    previewUrl: "#"
                },
                {
                    id: 13,
                    title: "Rozvrh zkoušek - leden 2025",
                    description: "Rozvrh zkouškového období na leden 2025. Obsahuje termíny, místnosti a zkušební komise.",
                    category: "schedule",
                    icon: "📝",
                    fileSize: "0.9 MB",
                    updated: "10.12.2024",
                    downloadUrl: "#",
                    previewUrl: "#"
                },
                {
                    id: 14,
                    title: "Metodické pokyny pro závěrečné práce",
                    description: "Podrobné metodické pokyny pro vypracování závěrečných prací - formátování, citace, struktura a hodnocení.",
                    category: "study",
                    icon: "✍️",
                    fileSize: "2.1 MB",
                    updated: "1.10.2024",
                    downloadUrl: "#",
                    previewUrl: "#"
                },
                {
                    id: 15,
                    title: "Návrh na změnu studijního plánu",
                    description: "Formulář pro podání návrhu na změnu individuálního studijního plánu. Vyplňte a odevzdejte studijnímu oddělení.",
                    category: "forms",
                    icon: "📄",
                    fileSize: "0.2 MB",
                    updated: "1.9.2024",
                    downloadUrl: "#",
                    previewUrl: "#"
                }
            ];

            // --- Pomocné funkce ---
            function getCategoryLabel(category) {
                const labels = {
                    'official': 'Oficiální',
                    'study': 'Studijní',
                    'forms': 'Formuláře',
                    'schedule': 'Rozvrh',
                    'other': 'Ostatní'
                };
                return labels[category] || 'Ostatní';
            }

            function getCategoryClass(category) {
                switch (category) {
                    case 'official': return 'doc-tag-official';
                    case 'study': return 'doc-tag-study';
                    case 'forms': return 'doc-tag-forms';
                    case 'schedule': return 'doc-tag-schedule';
                    default: return 'doc-tag-other';
                }
            }

            function escapeHtml(text) {
                if (!text) return '';
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            // --- Filtrování ---
            function getFilteredDocuments() {
                const categoryFilter = filterCategory.value;
                const searchTerm = filterSearch.value.toLowerCase().trim();

                return documents.filter(doc => {
                    if (categoryFilter !== 'all' && doc.category !== categoryFilter) return false;
                    if (searchTerm) {
                        const title = (doc.title || '').toLowerCase();
                        const desc = (doc.description || '').toLowerCase();
                        if (!title.includes(searchTerm) && !desc.includes(searchTerm)) return false;
                    }
                    return true;
                });
            }

            // --- Aktualizace statistik ---
            function updateStats() {
                const total = documents.length;
                const official = documents.filter(d => d.category === 'official').length;
                const study = documents.filter(d => d.category === 'study').length;
                const forms = documents.filter(d => d.category === 'forms').length;

                totalDocs.textContent = total;
                officialDocs.textContent = official;
                studyDocs.textContent = study;
                formsDocs.textContent = forms;
            }

            // --- Vykreslení dokumentů ---
            function renderDocuments() {
                const filtered = getFilteredDocuments();

                if (filtered.length === 0) {
                    documentsList.innerHTML = `
                        <div class="no-documents">
                            <span class="icon">📭</span>
                            ${documents.length === 0 ? 'Zatím zde nejsou žádné dokumenty.' : 'Žádné dokumenty neodpovídají zadanému filtru.'}
                        </div>
                    `;
                    docCount.innerHTML = `Celkem: <strong>0</strong> dokumentů`;
                    totalDocsDisplay.textContent = '0';
                    return;
                }

                let html = '';
                filtered.forEach(doc => {
                    const categoryLabel = getCategoryLabel(doc.category);
                    const categoryClass = getCategoryClass(doc.category);

                    html += `
                        <div class="doc-card">
                            <div class="doc-icon">${doc.icon || '📄'}</div>
                            <div class="doc-body">
                                <div class="doc-title">${escapeHtml(doc.title)}</div>
                                ${doc.description ? `<div class="doc-description">${escapeHtml(doc.description)}</div>` : ''}
                                <div class="doc-meta">
                                    <span class="doc-tag ${categoryClass}">${categoryLabel}</span>
                                    ${doc.fileSize ? `<span>📦 ${doc.fileSize}</span>` : ''}
                                    ${doc.updated ? `<span>🔄 ${doc.updated}</span>` : ''}
                                </div>
                            </div>
                            <div class="doc-actions no-print">
                                <a href="${doc.previewUrl || '#'}" class="btn-preview" target="_blank">👁️ Náhled</a>
                                <a href="${doc.downloadUrl || '#'}" class="btn-download" download>⬇️ Stáhnout</a>
                            </div>
                        </div>
                    `;
                });

                documentsList.innerHTML = html;
                const countText = filtered.length === documents.length 
                    ? `Celkem: <strong>${filtered.length}</strong> dokumentů`
                    : `Celkem: <strong>${filtered.length}</strong> dokumentů (z ${documents.length} celkem)`;
                docCount.innerHTML = countText;
                totalDocsDisplay.textContent = filtered.length;
            }

            // --- Filtry ---
            filterCategory.addEventListener('change', renderDocuments);
            filterSearch.addEventListener('input', renderDocuments);

            clearFilterBtn.addEventListener('click', function() {
                filterCategory.value = 'all';
                filterSearch.value = '';
                renderDocuments();
            });

            // --- Inicializace ---
            updateStats();
            renderDocuments();
        })();
    </script>
