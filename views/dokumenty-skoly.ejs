                icon: '📘'
            },
            {
                id: 'doc10',
                title: 'Metodický postup – BOZ na akcích',
                category: 'metodický',
                date: '2026-05-05',
                content: `📘 METODICKÝ POSTUP – BOZ NA ŠKOLNÍCH AKCÍCH\n\n1. Před akcí: písemný souhlas zákonného zástupce, poučení žáků.\n2. Během akce: vedoucí má seznam žáků, lékárničku, mobilní kontakt.\n3. Po akci: vyhodnocení, záznam o případném úrazu.\n\nPovinné dokumenty: bezpečnostní pokyn, vyúčtování.\n\nSchválil: Mgr. Helena Novotná, 5. 5. 2026`,
                icon: '📘'
            },
            {
                id: 'doc11',
                title: 'Cestovní příkaz – služební cesta',
                category: 'organizační',
                date: '2026-06-25',
                content: `🧳 CESTOVNÍ PŘÍKAZ\n\nJméno: Mgr. Helena Novotná\nCíl cesty: Školení BOZ, Hradec Králové\nDatum: 25. 6. 2026\nÚčel: služební cesta\nDopravní prostředek: vlak\n\nSchvaluji: Mgr. Helena Novotná\nV ZŠ a MŠ Pod Lípou, Praha, 25. 6. 2026`,
                icon: '🚗'
            },
            {
                id: 'doc12',
                title: 'Propustka z vyučování',
                category: 'organizační',
                date: '2026-06-17',
                content: `🔓 PROPUSTKA Z VYUČOVÁNÍ\n\nŽák: Adam Novák, třída 9.A\nDůvod uvolnění: návštěva lékaře\nČas uvolnění: 10:30\nPodpis zákonného zástupce: Jana Nováková\n\nV ZŠ a MŠ Pod Lípou, Praha, 17. 6. 2026\n\nMgr. Helena Novotná`,
                icon: '🚪'
            }
        ];

        let currentView = 'grid';
        let currentFilter = 'all';
        let searchQuery = '';
        let editingId = null;

        // DOM
        const docGrid = document.getElementById('docGrid');
        const searchInput = document.getElementById('searchInput');
        const categoryFilter = document.getElementById('categoryFilter');
        const viewGridBtn = document.getElementById('viewGrid');
        const viewListBtn = document.getElementById('viewList');
        const addDocBtn = document.getElementById('addDocBtn');
        const modalOverlay = document.getElementById('detailModal');
        const modalClose = document.getElementById('modalClose');
        const modalCloseBtn = document.getElementById('modalCloseBtn');
        const modalTitle = document.getElementById('modalTitle');
        const modalCategory = document.getElementById('modalCategory');
        const modalDate = document.getElementById('modalDate');
        const modalContent = document.getElementById('modalContent');
        const modalPrint = document.getElementById('modalPrint');
        const modalEdit = document.getElementById('modalEdit');
        const modalDelete = document.getElementById('modalDelete');
        const docCount = document.getElementById('docCount');
        const totalCount = document.getElementById('totalCount');
        const categoryCount = document.getElementById('categoryCount');

        // --- pomocné funkce ---
        function formatDate(dateStr) {
            if (!dateStr) return 'bez data';
            const d = new Date(dateStr);
            return d.toLocaleDateString('cs-CZ');
        }

        function getCategoryLabel(cat) {
            const map = {
                'výchovná': 'Výchovná',
                'organizační': 'Organizační',
                'hlášení': 'Hlášení & výkazy',
                'gdpr': 'GDPR & souhlasy',
                'metodický': 'Metodické postupy',
                'ostatní': 'Ostatní'
            };
            return map[cat] || cat;
        }

        function getCategoryColor(cat) {
            const map = {
                'výchovná': '#f59e0b',
                'organizační': '#3b82f6',
                'hlášení': '#ef4444',
                'gdpr': '#8b5cf6',
                'metodický': '#10b981',
                'ostatní': '#6b7280'
            };
            return map[cat] || '#6b7280';
        }

        // --- filtrování a řazení ---
        function getFilteredDocs() {
            return documents.filter(doc => {
                const matchSearch = doc.title.toLowerCase().includes(searchQuery.toLowerCase()) ||
                                   doc.content.toLowerCase().includes(searchQuery.toLowerCase());
                const matchCategory = currentFilter === 'all' || doc.category === currentFilter;
                return matchSearch && matchCategory;
            });
        }

        // --- renderování ---
        function render() {
            const filtered = getFilteredDocs();
            const total = documents.length;
            const cats = new Set(documents.map(d => d.category));
            docCount.textContent = filtered.length;
            totalCount.textContent = total;
            categoryCount.textContent = cats.size;

            if (filtered.length === 0) {
                docGrid.innerHTML = `
                    <div class="empty-state">
                        <h3>📭 Žádné dokumenty nenalezeny</h3>
                        <p>Zkuste upravit filtr nebo přidejte nový dokument.</p>
                    </div>
                `;
                return;
            }

            if (currentView === 'grid') {
                docGrid.className = 'doc-grid';
                docGrid.innerHTML = filtered.map(doc => `
                    <div class="doc-card" data-id="${doc.id}">
                        <div class="doc-header">
                            <span class="doc-icon">${doc.icon || '📄'}</span>
                            <span class="doc-title">${doc.title}</span>
                            <span class="doc-category" style="background:${getCategoryColor(doc.category)}20; color:${getCategoryColor(doc.category)};">
                                ${getCategoryLabel(doc.category)}
                            </span>
                        </div>
                        <div class="doc-meta">
                            <span>📅 ${formatDate(doc.date)}</span>
                            <span>📂 ${getCategoryLabel(doc.category)}</span>
                        </div>
                        <div class="doc-preview">${doc.content.substring(0, 120)}${doc.content.length > 120 ? '...' : ''}</div>
                        <div class="doc-actions">
                            <button class="btn btn-small btn-outline view-doc" data-id="${doc.id}">👁️ Detail</button>
                            <button class="btn btn-small btn-outline edit-doc" data-id="${doc.id}">✏️</button>
                            <button class="btn btn-small btn-danger delete-doc" data-id="${doc.id}">🗑️</button>
                        </div>
                    </div>
                `).join('');

                // Eventy pro karty
                document.querySelectorAll('.view-doc').forEach(btn => {
                    btn.addEventListener('click', () => openDetail(btn.dataset.id));
                });
                document.querySelectorAll('.edit-doc').forEach(btn => {
                    btn.addEventListener('click', () => editDocument(btn.dataset.id));
                });
                document.querySelectorAll('.delete-doc').forEach(btn => {
                    btn.addEventListener('click', () => deleteDocument(btn.dataset.id));
                });

            } else {
                // List view
                docGrid.className = 'doc-grid';
                docGrid.style.display = 'block';
                docGrid.innerHTML = `
                    <div style="background:white; border-radius:20px; border:1px solid #e2e8f0; overflow:hidden;">
                        <table style="width:100%; border-collapse:collapse; font-size:0.9rem;">
                            <thead style="background:#f8fafc; border-bottom:1px solid #e2e8f0;">
                                <tr>
                                    <th style="padding:0.8rem 1rem; text-align:left;">Název</th>
                                    <th style="padding:0.8rem 1rem; text-align:left;">Kategorie</th>
                                    <th style="padding:0.8rem 1rem; text-align:left;">Datum</th>
                                    <th style="padding:0.8rem 1rem; text-align:right;">Akce</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${filtered.map(doc => `
                                    <tr style="border-bottom:1px solid #f1f5f9;" data-id="${doc.id}">
                                        <td style="padding:0.7rem 1rem;"><strong>${doc.icon || '📄'} ${doc.title}</strong></td>
                                        <td style="padding:0.7rem 1rem;"><span class="doc-category" style="background:${getCategoryColor(doc.category)}20; color:${getCategoryColor(doc.category)};">${getCategoryLabel(doc.category)}</span></td>
                                        <td style="padding:0.7rem 1rem; color:#475569;">${formatDate(doc.date)}</td>
                                        <td style="padding:0.7rem 1rem; text-align:right;">
                                            <button class="btn btn-small btn-outline view-doc" data-id="${doc.id}">👁️</button>
                                            <button class="btn btn-small btn-outline edit-doc" data-id="${doc.id}">✏️</button>
                                            <button class="btn btn-small btn-danger delete-doc" data-id="${doc.id}">🗑️</button>
                                        </td>
                                    </tr>
                                `).join('')}
                            </tbody>
                        </table>
                    </div>
                `;
                docGrid.style.display = 'grid';

                // Eventy pro list
                document.querySelectorAll('.view-doc').forEach(btn => {
                    btn.addEventListener('click', () => openDetail(btn.dataset.id));
                });
                document.querySelectorAll('.edit-doc').forEach(btn => {
                    btn.addEventListener('click', () => editDocument(btn.dataset.id));
                });
                document.querySelectorAll('.delete-doc').forEach(btn => {
                    btn.addEventListener('click', () => deleteDocument(btn.dataset.id));
                });
            }
        }

        // --- Detail dokumentu ---
        function openDetail(id) {
            const doc = documents.find(d => d.id === id);
            if (!doc) return;
            modalTitle.textContent = doc.title;
            modalCategory.textContent = getCategoryLabel(doc.category);
            modalCategory.style.background = getCategoryColor(doc.category) + '20';
            modalCategory.style.color = getCategoryColor(doc.category);
            modalDate.textContent = '📅 ' + formatDate(doc.date);
            modalContent.textContent = doc.content;
            modalOverlay.classList.add('active');
            // uložíme id pro akce
            modalOverlay.dataset.docId = id;
        }

        function closeModal() {
            modalOverlay.classList.remove('active');
        }

        // --- Editace dokumentu ---
        function editDocument(id) {
            const doc = documents.find(d => d.id === id);
            if (!doc) return;
            const newTitle = prompt('Upravit název:', doc.title);
            if (newTitle !== null && newTitle.trim() !== '') doc.title = newTitle.trim();
            const newContent = prompt('Upravit obsah:', doc.content);
            if (newContent !== null && newContent.trim() !== '') doc.content = newContent.trim();
            const newCategory = prompt('Upravit kategorii (výchovná, organizační, hlášení, gdpr, metodický, ostatní):', doc.category);
            if (newCategory !== null && ['výchovná','organizační','hlášení','gdpr','metodický','ostatní'].includes(newCategory.trim())) {
                doc.category = newCategory.trim();
            }
            render();
        }

        // --- Smazání dokumentu ---
        function deleteDocument(id) {
            if (!confirm('Opravdu chcete smazat tento dokument?')) return;
            documents = documents.filter(d => d.id !== id);
            closeModal();
            render();
        }

        // --- Přidání nového dokumentu ---
        function addDocument() {
            const title = prompt('Zadejte název dokumentu:', 'Nový dokument');
            if (!title || title.trim() === '') return;
            const content = prompt('Zadejte obsah dokumentu:', 'Obsah...');
            if (content === null) return;
            const category = prompt('Kategorie (výchovná, organizační, hlášení, gdpr, metodický, ostatní):', 'ostatní');
            let cat = 'ostatní';
            if (category && ['výchovná','organizační','hlášení','gdpr','metodický','ostatní'].includes(category.trim())) {
                cat = category.trim();
            }
            const newDoc = {
                id: 'doc' + Date.now(),
                title: title.trim(),
                content: content.trim() || 'Obsah dokumentu',
                category: cat,
                date: new Date().toISOString().split('T')[0],
                icon: '📄'
            };
            documents.push(newDoc);
            render();
        }

        // --- Tisk dokumentu z modalu ---
        function printModalDoc() {
            const id = modalOverlay.dataset.docId;
            const doc = documents.find(d => d.id === id);
            if (!doc) return;
            const win = window.open('', '_blank', 'width=600,height=500');
            win.document.write(`
                <!DOCTYPE html>
                <html><head><meta charset="UTF-8"><title>${doc.title}</title>
                <style>body { font-family: 'Times New Roman', Times, serif; padding: 2rem; max-width: 700px; margin: 0 auto; line-height:1.6; }</style>
                </head><body><h2>${doc.title}</h2><p style="color:#475569;">${formatDate(doc.date)} • ${getCategoryLabel(doc.category)}</p><hr><pre style="white-space:pre-wrap; font-family:inherit;">${doc.content}</pre></body></html>
            `);
            win.document.close();
            win.print();
        }

        // --- Eventy ---
        searchInput.addEventListener('input', () => {
            searchQuery = searchInput.value;
            render();
        });

        categoryFilter.addEventListener('change', () => {
            currentFilter = categoryFilter.value;
            render();
        });

        viewGridBtn.addEventListener('click', () => {
            currentView = 'grid';
            viewGridBtn.classList.add('active');
            viewListBtn.classList.remove('active');
            render();
        });

        viewListBtn.addEventListener('click', () => {
            currentView = 'list';
            viewListBtn.classList.add('active');
            viewGridBtn.classList.remove('active');
            render();
        });

        addDocBtn.addEventListener('click', addDocument);

        modalClose.addEventListener('click', closeModal);
        modalCloseBtn.addEventListener('click', closeModal);
        modalOverlay.addEventListener('click', (e) => {
            if (e.target === modalOverlay) closeModal();
        });

        modalPrint.addEventListener('click', printModalDoc);

        modalEdit.addEventListener('click', () => {
            const id = modalOverlay.dataset.docId;
            if (id) {
                closeModal();
                editDocument(id);
            }
        });

        modalDelete.addEventListener('click', () => {
            const id = modalOverlay.dataset.docId;
            if (id) {
                closeModal();
                deleteDocument(id);
            }
        });

        // Klávesová zkratka Escape pro zavření modalu
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeModal();
        });

        // --- inicializace ---
        render();
    })();
</script>
</body>
</html>