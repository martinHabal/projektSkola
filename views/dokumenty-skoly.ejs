    <body>

        <%- include('./partials/header') %>
    <div class="container" id="app">
        <h1>📚 Školní dokumenty</h1>
        <p class="subtitle">Přehled důležitých dokumentů a formulářů</p>
        <hr class="header-line">

        <!-- Statistiky -->
        <div class="stats-section no-print">
            <div class="stat-card">
                <span class="stat-number" id="totalDocs">0</span>
                <span class="stat-label">📄 Celkem dokumentů</span>
            </div>
            <div class="stat-card">
                <span class="stat-number" id="officialDocs">0</span>
                <span class="stat-label">🏛️ Oficiální</span>
            </div>
            <div class="stat-card">
                <span class="stat-number" id="studyDocs">0</span>
                <span class="stat-label">📖 Studijní</span>
            </div>
            <div class="stat-card">
                <span class="stat-number" id="formsDocs">0</span>
                <span class="stat-label">📋 Formuláře</span>
            </div>
        </div>

        <!-- Filtr -->
        <div class="filter-section no-print">
            <label for="filterCategory">🔍 Filtrovat:</label>
            <select id="filterCategory">
                <option value="all">Všechny kategorie</option>
                <option value="official">Oficiální dokumenty</option>
                <option value="study">Studijní materiály</option>
                <option value="forms">Formuláře</option>
                <option value="schedule">Rozvrhy a plány</option>
                <option value="other">Ostatní</option>
            </select>
            <input type="text" id="filterSearch" placeholder="Hledat v názvu nebo popisu...">
            <button class="filter-clear" id="clearFilterBtn">✕ Vymazat filtr</button>
        </div>

        <!-- Legenda -->
        <div class="legenda no-print">
            <div class="legenda-item"><span class="color-box" style="background-color:#e3f2fd;"></span> Oficiální dokumenty</div>
            <div class="legenda-item"><span class="color-box" style="background-color:#fff3e0;"></span> Studijní materiály</div>
            <div class="legenda-item"><span class="color-box" style="background-color:#fce4ec;"></span> Formuláře</div>
            <div class="legenda-item"><span class="color-box" style="background-color:#f3e5f5;"></span> Rozvrhy a plány</div>
            <div class="legenda-item"><span class="color-box" style="background-color:#e8f5e9;"></span> Ostatní</div>
        </div>

        <!-- Počet dokumentů -->
        <div class="doc-count" id="docCount">Celkem: <strong>0</strong> dokumentů</div>

        <!-- Seznam dokumentů -->
        <div class="documents-list" id="documentsList">
            <div class="no-documents">
                <span class="icon">📭</span>
                Zatím zde nejsou žádné dokumenty.
            </div>
        </div>

        <div class="update-info no-print">
            📊 Zobrazeno <strong id="totalDocsDisplay">0</strong> dokumentů 
            <span class="badge">Demo data</span>
        </div>
    </div>

    <script>
        (function() {
            "use strict";

            // --- DOM odkazy ---
            const documentsList = document.getElementById('documentsList');
            const docCount = document.getElementById('docCount');
            const totalDocsDisplay = document.getElementById('totalDocsDisplay');
            const totalDocs = document.getElementById('totalDocs');
            const officialDocs = document.getElementById('officialDocs');
            const studyDocs = document.getElementById('studyDocs');
            const formsDocs = document.getElementById('formsDocs');
            const filterCategory = document.getElementById('filterCategory');
            const filterSearch = document.getElementById('filterSearch');
            const clearFilterBtn = document.getElementById('clearFilterBtn');

            // --- UKÁZKOVÁ DATA (simulace dat od vedení školy) ---
            const documents = [
                {
                    id: 1,
                    title: "Školní řád 2024/2025",
                    description: "Kompletní školní řád pro akademický rok 2024/2025. Obsahuje práva a povinnosti studentů, provozní řád a důležité informace.",
                    category: "official",
