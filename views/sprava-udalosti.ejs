<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <style>
        /* Vlož všechny CSS styly, které jsi poskytl */
        * {
            box-sizing: border-box;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f5f7fa;
            color: #333;
            margin: 0;
            padding: 20px;
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            background-color: white;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            padding: 25px;
        }

        h1 {
            color: #2c3e50;
            text-align: center;
            margin-bottom: 10px;
            padding-bottom: 15px;
            font-size: clamp(1.5rem, 4vw, 2.2rem);
        }

        .subtitle {
            text-align: center;
            color: #7f8c8d;
            margin-bottom: 25px;
            font-size: clamp(0.9rem, 2vw, 1.1rem);
        }

        /* Notifikace */
        .notification {
            padding: 15px 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-weight: 600;
            display: none;
        }

        .notification.show {
            display: block;
        }

        .notification-success {
            background-color: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .notification-error {
            background-color: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        /* Sekce pro vedení (přidávání událostí) */
        .admin-section {
            background-color: #f8f9fa;
            padding: 20px;
            margin-bottom: 30px;
            border-left: 4px solid #9b59b6;
            border-radius: 0 8px 8px 0;
        }

        .admin-section h3 {
            margin-top: 0;
            color: #2c3e50;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .admin-section h3 .badge {
            background-color: #9b59b6;
            color: white;
            font-size: 0.7rem;
            padding: 2px 10px;
            border-radius: 20px;
            font-weight: normal;
        }

        .admin-form {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            align-items: flex-end;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 5px;
            flex: 1 1 180px;
        }

        .form-group label {
            font-weight: 600;
            color: #2c3e50;
            font-size: 0.85rem;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            padding: 8px 12px;
            border: 1px solid #bdc3c7;
            border-radius: 5px;
            font-size: 0.95rem;
            background-color: white;
            width: 100%;
        }

        .form-group textarea {
            resize: vertical;
            min-height: 60px;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: 2px solid #9b59b6;
            border-color: transparent;
        }

        .form-group .error-text {
            color: #e74c3c;
            font-size: 0.8rem;
            margin-top: 3px;
        }

        .form-group .field-error {
            border-color: #e74c3c !important;
        }

        .btn-add {
            background-color: #9b59b6;
            color: white;
            padding: 8px 25px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: 600;
            font-size: 1rem;
            transition: background-color 0.3s;
            height: 42px;
            align-self: flex-end;
            flex: 0 0 auto;
        }

        .btn-add:hover {
            background-color: #8e44ad;
        }

        .btn-add:disabled {
            background-color: #bdc3c7;
            cursor: not-allowed;
        }

        /* Filtr a vyhledávání */
        .filter-section {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 25px;
            padding: 15px;
            background-color: #f8f9fa;
            border-radius: 8px;
            align-items: center;
        }

        .filter-section label {
            font-weight: 600;
            color: #2c3e50;
            font-size: 0.9rem;
            white-space: nowrap;
        }

        .filter-section select,
        .filter-section input {
            padding: 8px 12px;
            border: 1px solid #bdc3c7;
            border-radius: 5px;
            font-size: 0.95rem;
            background-color: white;
        }

        .filter-section input {
            flex: 1 1 200px;
            min-width: 150px;
        }

        .filter-section select {
            min-width: 130px;
        }

        .filter-clear {
            background-color: #e74c3c;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.9rem;
            transition: background-color 0.3s;
            text-decoration: none;
            display: inline-block;
        }

        .filter-clear:hover {
            background-color: #c0392b;
        }

        .btn-filter {
            background-color: #3498db;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.9rem;
            transition: background-color 0.3s;
        }

        .btn-filter:hover {
            background-color: #2980b9;
        }

        /* Legenda */
        .legenda {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 25px;
            padding: 15px;
            background-color: #f8f9fa;
            border-left: 4px solid #3498db;
        }

        .legenda-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: clamp(0.8rem, 1.8vw, 0.9rem);
        }

        .color-box {
            width: 20px;
            height: 20px;
            border-radius: 3px;
            border: 1px solid #ddd;
            flex-shrink: 0;
        }

        /* Seznam událostí */
        .events-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin-top: 10px;
        }

        .event-card {
            background-color: white;
            border: 1px solid #e0e0e0;
            border-radius: 10px;
            padding: 18px 22px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            transition: box-shadow 0.3s, transform 0.2s;
            display: grid;
            grid-template-columns: auto 1fr auto;
            gap: 15px 25px;
            align-items: center;
        }

        .event-card:hover {
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            transform: translateY(-2px);
        }

        .event-card .event-date {
            font-weight: 700;
            color: #2c3e50;
            font-size: clamp(1rem, 2vw, 1.15rem);
            white-space: nowrap;
            min-width: 120px;
        }

        .event-card .event-date .day-name {
            font-weight: 400;
            color: #7f8c8d;
            font-size: 0.8rem;
            display: block;
        }

        .event-card .event-body {
            flex: 1;
        }

        .event-card .event-title {
            font-weight: 600;
            font-size: clamp(1rem, 2vw, 1.2rem);
            color: #2c3e50;
            margin-bottom: 4px;
        }

        .event-card .event-description {
            color: #555;
            font-size: clamp(0.85rem, 1.8vw, 0.95rem);
            line-height: 1.5;
            word-break: break-word;
        }

        .event-card .event-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 6px;
            font-size: 0.8rem;
            color: #7f8c8d;
        }

        .event-card .event-meta span {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .event-card .event-type {
            display: inline-block;
            padding: 2px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            white-space: nowrap;
        }

        .event-type-meeting {
            background-color: #e3f2fd;
            color: #1565c0;
        }

        .event-type-training {
            background-color: #fff3e0;
            color: #e65100;
        }

        .event-type-social {
            background-color: #fce4ec;
            color: #c62828;
        }

        .event-type-deadline {
            background-color: #f3e5f5;
            color: #6a1b9a;
        }

        .event-type-other {
            background-color: #e8f5e9;
            color: #2e7d32;
        }

        .event-card .event-actions {
            display: flex;
            gap: 8px;
            align-self: flex-start;
            margin-top: 4px;
        }

        .event-card .event-actions button,
        .event-card .event-actions form {
            display: inline-block;
        }

        .event-card .event-actions button {
            background: none;
            border: none;
            cursor: pointer;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 1.1rem;
            transition: background-color 0.2s;
            color: #7f8c8d;
        }

        .event-card .event-actions .btn-delete-event:hover {
            background-color: #ffebee;
            color: #e74c3c;
        }

        .event-card .event-actions .btn-edit-event:hover {
            background-color: #e3f2fd;
            color: #2980b9;
        }

        /* Stav, když nejsou události */
        .no-events {
            text-align: center;
            padding: 40px 20px;
            color: #7f8c8d;
            font-style: italic;
            background-color: #fafafa;
            border-radius: 10px;
            border: 2px dashed #ddd;
        }

        .no-events .icon {
            font-size: 3rem;
            display: block;
            margin-bottom: 10px;
        }

        /* Tlačítka admin */
        .admin-actions {
            display: flex;
            gap: 15px;
            margin-top: 15px;
            flex-wrap: wrap;
        }

        .btn-danger {
            background-color: #ff000091;
            color: white;
            padding: 8px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: 600;
            transition: background-color 0.3s;
        }

        .btn-danger:hover {
            background-color: #e74c3c;
        }

        /* Počet událostí */
        .event-count {
            text-align: right;
            font-size: 0.9rem;
            color: #7f8c8d;
            margin-bottom: 10px;
        }

        .event-count strong {
            color: #2c3e50;
        }

        /* Modal pro úpravu */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal-overlay.active {
            display: flex;
        }

        .modal-content {
            background-color: white;
            padding: 30px;
            border-radius: 12px;
            width: 90%;
            max-width: 600px;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        }

        .modal-content h3 {
            margin-top: 0;
            color: #2c3e50;
            border-bottom: 2px solid #9b59b6;
            padding-bottom: 12px;
        }

        .modal-content .form-group {
            margin-bottom: 15px;
        }

        .modal-buttons {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 20px;
        }

        .modal-buttons button {
            padding: 8px 25px;
            border: none;
            border-radius: 5px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.3s;
        }

        .modal-buttons .btn-modal-cancel {
            background-color: #e74c3c;
            color: white;
        }

        .modal-buttons .btn-modal-cancel:hover {
            background-color: #c0392b;
        }

        .modal-buttons .btn-modal-save {
            background-color: #9b59b6;
            color: white;
        }

        .modal-buttons .btn-modal-save:hover {
            background-color: #8e44ad;
        }

        @media (max-width: 768px) {
            .event-card {
                grid-template-columns: 1fr;
                gap: 10px;
            }
            
            .event-card .event-date {
                min-width: unset;
            }
            
            .admin-form {
                flex-direction: column;
            }
            
            .btn-add {
                width: 100%;
                align-self: stretch;
            }
            
            .filter-section {
                flex-direction: column;
                align-items: stretch;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>📅 Správa událostí</h1>
        <p class="subtitle">Přehled a správa všech plánovaných událostí</p>

        <!-- Notifikace -->
        <% if (locals.success) { %>
            <div class="notification notification-success show">
                ✅ Událost byla úspěšně přidána!
            </div>
        <% } %>
        
        <% if (locals.deleted) { %>
            <div class="notification notification-success show">
                🗑 Událost byla smazána!
            </div>
        <% } %>
        
        <% if (locals.updated) { %>
            <div class="notification notification-success show">
                ✅ Událost byla úspěšně upravena!
            </div>
        <% } %>
        
        <% if (locals.error) { %>
            <div class="notification notification-error show">
                ❌ Došlo k chybě při zpracování!
            </div>
        <% } %>

        <!-- Sekce pro přidávání -->
        <div class="admin-section">
            <h3>
                ➕ Přidat novou událost
                <span class="badge">Admin</span>
            </h3>
            
            <!-- KONTROLA EXISTENCE errors -->
            <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
                <div class="notification notification-error show">
                    <strong>Chyby ve formuláři:</strong>
                    <ul style="margin: 5px 0 0 20px;">
                        <% errors.forEach(err => { %>
                            <li><%= err %></li>
                        <% }) %>
                    </ul>
                </div>
            <% } %>
            
            <form action="/add-event" method="POST" class="admin-form">
                <div class="form-group">
                    <label for="eventTitle">Název *</label>
                    <input 
                        type="text" 
                        id="eventTitle" 
                        name="title" 
                        value="<%= (typeof formData !== 'undefined' && formData && formData.title) ? formData.title : '' %>"
                        placeholder="Např. Čtvrtletní porada" 
                        class="<%= (typeof errors !== 'undefined' && errors && errors.length > 0) ? 'field-error' : '' %>"
                        required 
                    />
                </div>
                <div class="form-group">
                    <label for="eventDate">Datum *</label>
                    <input 
                        type="date" 
                        id="eventDate" 
                        name="date" 
                        value="<%= (typeof formData !== 'undefined' && formData && formData.date) ? formData.date : new Date().toISOString().slice(0,10) %>"
                        class="<%= (typeof errors !== 'undefined' && errors && errors.length > 0) ? 'field-error' : '' %>"
                        required 
                    />
                </div>
                <div class="form-group">
                    <label for="eventType">Typ *</label>
                    <select 
                        id="eventType" 
                        name="type"
                        class="<%= (typeof errors !== 'undefined' && errors && errors.length > 0) ? 'field-error' : '' %>"
                        required
                    >
                        <option value="">-- Vyberte --</option>
                        <option value="meeting" <%= (typeof formData !== 'undefined' && formData && formData.type === 'meeting') ? 'selected' : '' %>>Meeting</option>
                        <option value="training" <%= (typeof formData !== 'undefined' && formData && formData.type === 'training') ? 'selected' : '' %>>Školení</option>
                        <option value="social" <%= (typeof formData !== 'undefined' && formData && formData.type === 'social') ? 'selected' : '' %>>Společenská</option>
                        <option value="deadline" <%= (typeof formData !== 'undefined' && formData && formData.type === 'deadline') ? 'selected' : '' %>>Deadline</option>
                        <option value="other" <%= (typeof formData !== 'undefined' && formData && formData.type === 'other') ? 'selected' : '' %>>Jiné</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="eventDescription">Popis</label>
                    <textarea 
                        id="eventDescription" 
                        name="description" 
                        placeholder="Podrobný popis události..."
                    ><%= (typeof formData !== 'undefined' && formData && formData.description) ? formData.description : '' %></textarea>
                </div>
                <button type="submit" class="btn-add">Přidat</button>
            </form>
        </div>

        <!-- Filtrování -->
        <form action="/filter" method="GET" class="filter-section">
            <label for="filterType">🔍 Filtr:</label>
            <select id="filterType" name="type">
                <option value="all" <%= (typeof filterType !== 'undefined' && filterType === 'all') ? 'selected' : '' %>>Všechny typy</option>
                <option value="meeting" <%= (typeof filterType !== 'undefined' && filterType === 'meeting') ? 'selected' : '' %>>Meeting</option>
                <option value="training" <%= (typeof filterType !== 'undefined' && filterType === 'training') ? 'selected' : '' %>>Školení</option>
                <option value="social" <%= (typeof filterType !== 'undefined' && filterType === 'social') ? 'selected' : '' %>>Společenská</option>
                <option value="deadline" <%= (typeof filterType !== 'undefined' && filterType === 'deadline') ? 'selected' : '' %>>Deadline</option>
                <option value="other" <%= (typeof filterType !== 'undefined' && filterType === 'other') ? 'selected' : '' %>>Jiné</option>
            </select>
            <input 
                type="text" 
                name="search" 
                placeholder="Hledat podle názvu..." 
                value="<%= (typeof searchQuery !== 'undefined') ? searchQuery : '' %>"
            />
            <button type="submit" class="btn-filter">🔍 Filtrovat</button>
            <a href="/" class="filter-clear">✕ Zrušit filtry</a>
        </form>

        <!-- Legenda -->
        <div class="legenda">
            <div class="legenda-item">
                <span class="color-box" style="background-color: #e3f2fd;"></span>
                Meeting
            </div>
            <div class="legenda-item">
                <span class="color-box" style="background-color: #fff3e0;"></span>
                Školení
            </div>
            <div class="legenda-item">
                <span class="color-box" style="background-color: #fce4ec;"></span>
                Společenská
            </div>
            <div class="legenda-item">
                <span class="color-box" style="background-color: #f3e5f5;"></span>
                Deadline
            </div>
            <div class="legenda-item">
                <span class="color-box" style="background-color: #e8f5e9;"></span>
                Jiné
            </div>
        </div>

        <!-- Počet a seznam událostí -->
        <div class="event-count">
            Celkem: <strong><%= (typeof totalCount !== 'undefined') ? totalCount : 0 %></strong> událostí
            <% if (typeof events !== 'undefined' && events && events.length !== totalCount) { %>
                (zobrazeno: <strong><%= events.length %></strong>)
            <% } %>
        </div>

        <div class="events-list">
            <% if (typeof events !== 'undefined' && events && events.length > 0) { %>
                <% events.forEach(event => { %>
                    <div class="event-card">
                        <div class="event-date">
                            <%= new Date(event.date).toLocaleDateString('cs-CZ') %>
                            <span class="day-name">
                                <%= ['Neděle', 'Pondělí', 'Úterý', 'Středa', 'Čtvrtek', 'Pátek', 'Sobota'][new Date(event.date + 'T00:00:00').getDay()] %>
                            </span>
                        </div>
                        <div class="event-body">
                            <div class="event-title"><%= event.title %></div>
                            <% if (event.description) { %>
                                <div class="event-description"><%= event.description %></div>
                            <% } %>
                            <div class="event-meta">
                                <span class="event-type event-type-<%= event.type %>"><%= event.type %></span>
                                <span>🆔 #<%= event.id %></span>
                            </div>
                        </div>
                        <div class="event-actions">
                            <button class="btn-edit-event" onclick="openEditModal(<%= event.id %>)" title="Upravit">✏️</button>
                            <form action="/delete-event/<%= event.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Opravdu chcete smazat tuto událost?');">
                                <button type="submit" class="btn-delete-event" title="Smazat">🗑</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="no-events">
                    <span class="icon">📭</span>
                    <p>Žádné události nenalezeny</p>
                    <small style="color: #999;">Zkuste upravit filtry nebo přidejte novou událost</small>
                </div>
            <% } %>
        </div>

        <!-- Admin akce -->
        <div class="admin-actions">
            <form action="/delete-all" method="POST" onsubmit="return confirm('Opravdu chcete smazat VŠECHNY události? Tato akce je nevratná!');">
                <button type="submit" class="btn-danger">🗑 Smazat všechny události</button>
            </form>
        </div>
    </div>

    <!-- Modal pro úpravu -->
    <div id="editModal" class="modal-overlay">
        <div class="modal-content">
            <h3>✏️ Upravit událost</h3>
            <form id="editForm" action="" method="POST">
                <input type="hidden" id="editId" name="id" />
                <div class="form-group">
                    <label for="editTitle">Název *</label>
                    <input type="text" id="editTitle" name="title" required />
                </div>
                <div class="form-group">
                    <label for="editDate">Datum *</label>
                    <input type="date" id="editDate" name="date" required />
                </div>
                <div class="form-group">
                    <label for="editType">Typ *</label>
                    <select id="editType" name="type" required>
                        <option value="meeting">Meeting</option>
                        <option value="training">Školení</option>
                        <option value="social">Společenská</option>
                        <option value="deadline">Deadline</option>
                        <option value="other">Jiné</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="editDescription">Popis</label>
                    <textarea id="editDescription" name="description" rows="3"></textarea>
                </div>
                <div class="modal-buttons">
                    <button type="button" class="btn-modal-cancel" onclick="closeModal()">Zrušit</button>
                    <button type="submit" class="btn-modal-save">Uložit změny</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // ============================================
        // FRONTEND JAVASCRIPT - POUZE PRO MODAL
        // ============================================

        const editModal = document.getElementById('editModal');
        const editForm = document.getElementById('editForm');

        // Otevření modalu a načtení dat přes API
        async function openEditModal(id) {
            try {
                const response = await fetch(`/api/event/${id}`);
                if (!response.ok) throw new Error('Chyba při načítání dat');
                
                const event = await response.json();
                
                // Nastavení hodnot do formuláře
                document.getElementById('editId').value = event.id;
                document.getElementById('editTitle').value = event.title;
                document.getElementById('editDate').value = event.date;
                document.getElementById('editType').value = event.type;
                document.getElementById('editDescription').value = event.description || '';
                
                // Nastavení action formuláře
                editForm.action = `/update-event/${event.id}`;
                
                // Zobrazení modalu
                editModal.classList.add('active');
                
            } catch (error) {
                console.error('Chyba:', error);
                alert('Nepodařilo se načíst data události');
            }
        }

        // Zavření modalu
        function closeModal() {
            editModal.classList.remove('active');
        }

        // Zavření kliknutím mimo modal
        editModal.addEventListener('click', (e) => {
            if (e.target === editModal) {
                closeModal();
            }
        });

        // Zavření ESC klávesou
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeModal();
            }
        });

        // Automatické skrytí notifikací po 5 sekundách
        document.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => {
                document.querySelectorAll('.notification').forEach(notif => {
                    notif.classList.remove('show');
                });
            }, 5000);
        });

        // Pokud je edit_error, otevřít modal pro dané ID
        <% if (typeof editId !== 'undefined' && editId) { %>
            document.addEventListener('DOMContentLoaded', () => {
                openEditModal(<%= editId %>);
            });
        <% } %>


        //funkce z sablony firemni-udalosti na vykresleni udalosti
          (function() {
            "use strict";

            // --- DOM odkazy ---
            const eventsList = document.getElementById('eventsList');
            const eventCount = document.getElementById('eventCount');
            const totalEventsSpan = document.getElementById('totalEvents');
            const filterType = document.getElementById('filterType');
            const filterSearch = document.getElementById('filterSearch');
            const clearFilterBtn = document.getElementById('clearFilterBtn');
const events = <%- JSON.stringify(meetings) %>
console.log(events)
           

            // --- Pomocné funkce ---
            function formatDate(dateStr) {
                const d = new Date(dateStr + 'T00:00:00');
                const day = d.getDate();
                const month = d.getMonth() + 1;
                const year = d.getFullYear();
                const days = ['Neděle', 'Pondělí', 'Úterý', 'Středa', 'Čtvrtek', 'Pátek', 'Sobota'];
                const dayName = days[d.getDay()];
                return `${day}. ${month}. ${year}`;
            }

            function getDayName(dateStr) {
                const d = new Date(dateStr + 'T00:00:00');
                const days = ['Ne', 'Po', 'Út', 'St', 'Čt', 'Pá', 'So'];
                return days[d.getDay()];
            }

            function getTypeClass(type) {
                switch (type) {
                    case 'meeting': return 'event-type-meeting';
                    case 'training': return 'event-type-training';
                    case 'social': return 'event-type-social';
                    case 'deadline': return 'event-type-deadline';
                    default: return 'event-type-other';
                }
            }

            function getTypeLabel(type) {
                switch (type) {
                    case 'meeting': return 'Porada';
                    case 'training': return 'Školení';
                    case 'social': return 'Společenská';
                    case 'deadline': return 'Termín';
                    default: return 'Jiné';
                }
            }

            function isPastEvent(dateStr) {
                const today = new Date();
                today.setHours(0, 0, 0, 0);
                const eventDate = new Date(dateStr + 'T00:00:00');
                return eventDate < today;
            }

            function escapeHtml(text) {
                if (!text) return '';
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            // --- Filtrování ---
            function getFilteredEvents() {
                const typeFilter = filterType.value;
                const searchTerm = filterSearch.value.toLowerCase().trim();

                return events.filter(event => {
                    if (typeFilter !== 'all' && event.type !== typeFilter) return false;
                    if (searchTerm) {
                        const title = (event.title || '').toLowerCase();
                        const desc = (event.description || '').toLowerCase();
                        if (!title.includes(searchTerm) && !desc.includes(searchTerm)) return false;
                    }
                    return true;
                });
            }

            // --- Vykreslení událostí ---
            function renderEvents() {
                const filtered = getFilteredEvents();

                // Řazení podle data (nejbližší první)
                filtered.sort((a, b) => a.date.localeCompare(b.date));

                if (filtered.length === 0) {
                    eventsList.innerHTML = `
                        <div class="no-events">
                            <span class="icon">📭</span>
                            ${events.length === 0 ? 'Zatím zde nejsou žádné události.' : 'Žádné události neodpovídají zadanému filtru.'}
                        </div>
                    `;
                    eventCount.innerHTML = `Celkem: <strong>0</strong> událostí`;
                    totalEventsSpan.textContent = '0';
                    return;
                }

                let html = '';
                filtered.forEach(event => {
                    const dateStr = formatDate(event.date);
                    const dayName = getDayName(event.date);
                    const typeClass = getTypeClass(event.type);
                    const typeLabel = getTypeLabel(event.type);
                    const description = event.description || '';
                    const past = isPastEvent(event.date);

                    html += `
                        <div class="event-card" style="${past ? 'opacity: 0.6;' : ''}">
                            <div class="event-date">
                                ${dateStr}
                                <span class="day-name">${dayName}${past ? ' (proběhlo)' : ''}</span>
                            </div>
                            <div class="event-body">
                                <div class="event-title">${escapeHtml(event.title)}</div>
                                ${description ? `<div class="event-description">${escapeHtml(description)}</div>` : ''}
                                <div class="event-meta">
                                    <span class="event-type ${typeClass}">${typeLabel}</span>
                                </div>
                            </div>
                        </div>
                    `;
                });

                eventsList.innerHTML = html;
                const countText = filtered.length === events.length 
                    ? `Celkem: <strong>${filtered.length}</strong> událostí`
                    : `Celkem: <strong>${filtered.length}</strong> událostí (z ${events.length} celkem)`;
                eventCount.innerHTML = countText;
                totalEventsSpan.textContent = filtered.length;
            }

            // --- Filtry ---
            filterType.addEventListener('change', renderEvents);
            filterSearch.addEventListener('input', renderEvents);

            clearFilterBtn.addEventListener('click', function() {
                filterType.value = 'all';
                filterSearch.value = '';
                renderEvents();
            });

            // --- Inicializace ---
            renderEvents();
        })();
        
    </script>
</body>
</html>