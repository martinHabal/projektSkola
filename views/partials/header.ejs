    <% if (isAdmin) { %>
      <button class="tooltip" data-tooltip="Dashboard" onclick="window.location.href='/dashboard'"
        style="background-color: rgb(140, 16, 211);">
        <span class="material-icons">dashboard</span>
      </button>
      <% } %>
        <% if (isAdmin) { %>
          <button class="tooltip" data-tooltip="Nový uživatel" onclick="window.location.href='/new-user'"
            style="background-color: rgb(140, 16, 211);">
            <span class="material-icons">person_add</span>
          </button>
          <% } %>
            <button style="cursor: pointer" class="tooltip" data-tooltip="Odhlášení"
              onclick="window.location.href='/logout'" style="background-color: red;">
              <span class="material-icons">logout</span>
            </button>
            <% if (isAdmin) { %>
              <button style="cursor: pointer" class="tooltip" data-tooltip="Nová škola"
              onclick="window.location.href='/nova-skola'" style="background-color: rgb(140, 16, 211);">
              <span class="material-icons">home</span>
            </button>
            <% } %>
          </div>
      <!-- on vlastne header jako takovej neni, jsou to jen ty button odkazy, ale vypada to amatersky... musim tad dat klasickej header -->
      <div id="popup" style="
  display:none;
  position:fixed;
  top:50%;
  left:50%;
  transform:translate(-50%, -50%);
  background:white;
  padding:20px;
  border:1px solid black;
  box-shadow:0 0 10px rgba(0,0,0,0.3);
">
        <p>cv,zahrady-stavby,vykaz-tabulka,vykaz-info,vykaz,maturita,js-uvod</p>
        <button onclick="closePopup()">Zavřít</button>
      </div>

      <script>
        let clickCount = 0;
        const div = document.getElementById("header");
        const popup = document.getElementById("popup");

        div.addEventListener("click", () => {
          clickCount++;

          if (clickCount === 8) {
            popup.style.display = "block";
            clickCount = 0; // reset (volitelné)
          }
        });

        function closePopup() {
          popup.style.display = "none";
        }
      </script>
</header>