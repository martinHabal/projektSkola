<!DOCTYPE html>
<html lang="cs">

    <style>
        /* * {
            box-sizing: border-box;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f5f7fa;
            color: #333;
            margin: 0;
            padding: 20px;
            line-height: 1.6;
        } */

        .container {
            max-width: 1200px;
            margin: 0 auto;
            background-color: white;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            padding: 25px;
        }

        h1 {
            color: #2c3e50;
            text-align: center;
            margin-bottom: 5px;
            padding-bottom: 10px;
            font-size: clamp(1.5rem, 4vw, 2.2rem);
        }

        .subtitle {
            text-align: center;
            color: #7f8c8d;
            margin-bottom: 25px;
            font-size: clamp(0.9rem, 2vw, 1.1rem);
        }

        .header-line {
            border: none;
            height: 2px;
            background: linear-gradient(to right, transparent, #3498db, transparent);
            margin-bottom: 25px;
        }

        /* Filtr a vyhledávání */
        .filter-section {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 25px;
            padding: 15px 20px;
            background-color: #f8f9fa;
            border-radius: 8px;
            align-items: center;
        }

        .filter-section label {
            font-weight: 600;
            color: #2c3e50;
            font-size: 0.9rem;
            white-space: nowrap;
        }

        .filter-section select,
        .filter-section input {
            padding: 8px 12px;
            border: 1px solid #bdc3c7;
            border-radius: 5px;
            font-size: 0.95rem;
            background-color: white;
        }

        .filter-section input {
            flex: 1 1 200px;
            min-width: 150px;
        }

        .filter-section select {
            min-width: 130px;
        }

        .filter-clear {
            background-color: #e74c3c;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.9rem;
            transition: background-color 0.3s;
        }

        .filter-clear:hover {
            background-color: #c0392b;
        }

        /* Legenda */
        .legenda {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 25px;
            padding: 15px 20px;
            background-color: #f8f9fa;
            border-left: 4px solid #3498db;
            border-radius: 0 8px 8px 0;
        }

        .legenda-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: clamp(0.8rem, 1.8vw, 0.9rem);
        }

        .color-box {
            width: 20px;
            height: 20px;
            border-radius: 3px;
            border: 1px solid #ddd;
            flex-shrink: 0;
        }

        /* Seznam událostí */
        .events-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin-top: 10px;
        }

        .event-card {
            background-color: white;
            border: 1px solid #e8e8e8;
            border-radius: 10px;
            padding: 18px 22px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            transition: box-shadow 0.3s, transform 0.2s;
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 15px 25px;
            align-items: start;
        }

        .event-card:hover {
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            transform: translateY(-2px);
        }

        .event-card .event-date {
            font-weight: 700;
            color: #2c3e50;
            font-size: clamp(1rem, 2vw, 1.15rem);
            white-space: nowrap;
            min-width: 120px;
            padding-top: 2px;
        }

        .event-card .event-date .day-name {
            font-weight: 400;
            color: #7f8c8d;
            font-size: 0.8rem;
            display: block;
        }

        .event-card .event-body {
            flex: 1;
        }

        .event-card .event-title {
            font-weight: 600;
            font-size: clamp(1rem, 2vw, 1.2rem);
            color: #2c3e50;
            margin-bottom: 4px;
        }

        .event-card .event-description {
            color: #555;
            font-size: clamp(0.85rem, 1.8vw, 0.95rem);
            line-height: 1.5;
            word-break: break-word;
            margin-top: 4px;
        }

        .event-card .event-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 8px;
        }

        .event-card .event-type {
            display: inline-block;
            padding: 2px 14px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            white-space: nowrap;
        }

        .event-type-meeting {
            background-color: #e3f2fd;
            color: #1565c0;
        }

        .event-type-training {
            background-color: #fff3e0;
            color: #e65100;
        }

        .event-type-social {
            background-color: #fce4ec;
            color: #c62828;
        }

        .event-type-deadline {
            background-color: #f3e5f5;
            color: #6a1b9a;
        }

        .event-type-other {
            background-color: #e8f5e9;
            color: #2e7d32;
        }

        /* Stav, když nejsou události */
        .no-events {
            text-align: center;
            padding: 50px 20px;
            color: #7f8c8d;
            font-style: italic;
            background-color: #fafafa;
            border-radius: 10px;
            border: 2px dashed #ddd;
        }

        .no-events .icon {
            font-size: 3rem;
            display: block;
            margin-bottom: 10px;
        }

        /* Počet událostí */
        .event-count {
            text-align: right;
            font-size: 0.9rem;
            color: #7f8c8d;
            margin-bottom: 10px;
        }

        .event-count strong {
            color: #2c3e50;
        }

        /* Zpráva o aktualizaci */
        .update-info {
            text-align: center;
            font-size: 0.8rem;
            color: #95a5a6;
            margin-top: 20px;
            padding-top: 15px;
            border-top: 1px solid #eee;
        }

        .update-info .badge {
            display: inline-block;
            background-color: #27ae60;
            color: white;
            padding: 2px 10px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 600;
            margin-left: 8px;
        }

        /* Responzivní úpravy */
        @media (max-width: 768px) {
            .event-card {
                grid-template-columns: 1fr;
                gap: 8px;
            }

            .event-card .event-date {
                min-width: auto;
                display: flex;
                align-items: center;
                gap: 10px;
                flex-wrap: wrap;
            }

            .event-card .event-date .day-name {
                display: inline;
            }

            .filter-section {
                flex-direction: column;
                align-items: stretch;
            }

            .filter-section label {
                white-space: normal;
            }
        }

        @media print {
            .no-print {
                display: none !important;
            }
            .event-card {
                break-inside: avoid;
                border: 1px solid #ccc;
                box-shadow: none !important;
            }
            .container {
                box-shadow: none !important;
            }
        }
    </style>

<%- include('./partials/head') %>

    <body>
        <%- include('./partials/header') %>
    <div class="container" id="app">
        <h1>📅 Firemní události</h1>
        <p class="subtitle">Přehled všech plánovaných událostí</p>
        <hr class="header-line">

        <!-- Filtr -->
        <div class="filter-section no-print">
            <label for="filterType">🔍 Filtrovat:</label>
            <select id="filterType">
                <option value="all">Všechny typy</option>
                <option value="meeting">Porada / Meeting</option>
                <option value="training">Školení</option>
                <option value="social">Společenská akce</option>
                <option value="deadline">Termín odevzdání</option>
                <option value="other">Jiné</option>
            </select>
            <input type="text" id="filterSearch" placeholder="Hledat v názvu nebo popisu...">
            <button class="filter-clear" id="clearFilterBtn">✕ Vymazat filtr</button>
        </div>

        <!-- Legenda -->
        <div class="legenda no-print">
            <div class="legenda-item"><span class="color-box" style="background-color:#e3f2fd;"></span> Porada / Meeting</div>
            <div class="legenda-item"><span class="color-box" style="background-color:#fff3e0;"></span> Školení</div>
            <div class="legenda-item"><span class="color-box" style="background-color:#fce4ec;"></span> Společenská akce</div>
            <div class="legenda-item"><span class="color-box" style="background-color:#f3e5f5;"></span> Termín odevzdání</div>
            <div class="legenda-item"><span class="color-box" style="background-color:#e8f5e9;"></span> Jiné</div>
        </div>

        <!-- Počet událostí -->
        <div class="event-count" id="eventCount">Celkem: <strong>0</strong> událostí</div>

        <!-- Seznam událostí -->
        <div class="events-list" id="eventsList">
            <div class="no-events">
                <span class="icon">📭</span>
                Zatím zde nejsou žádné události.
            </div>
        </div>

        <div class="update-info no-print">
            📊 Zobrazeno <strong id="totalEvents">0</strong> událostí 
            <span class="badge">Demo data</span>
        </div>
    </div>

    <script>
        (function() {
            "use strict";

            // --- DOM odkazy ---
            const eventsList = document.getElementById('eventsList');
            const eventCount = document.getElementById('eventCount');
            const totalEventsSpan = document.getElementById('totalEvents');
            const filterType = document.getElementById('filterType');
            const filterSearch = document.getElementById('filterSearch');
            const clearFilterBtn = document.getElementById('clearFilterBtn');

            // --- UKÁZKOVÁ DATA (simulace dat od vedení) ---
            const events = [
                {
                    id: 1,
                    title: "Čtvrtletní porada vedení",
                    date: new Date(Date.now() + 2 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
                    type: "meeting",
                    description: "Hodnocení výsledků za poslední čtvrtletí a plánování dalšího období."
                },
                {
                    id: 2,
                    title: "Školení bezpečnosti práce",
                    date: new Date(Date.now() + 5 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
                    type: "training",
                    description: "Povinné školení BOZP pro všechny zaměstnance. Účast je povinná."
                },
                {
                    id: 3,
                    title: "Firemní vánoční večírek",
                    date: new Date(Date.now() + 14 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
                    type: "social",
                    description: "Tradiční firemní večírek v hotelu Grand. Rezervujte si datum!"
                },
                {
                    id: 4,
                    title: "Termín odevzdání projektů",
                    date: new Date(Date.now() + 9 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
                    type: "deadline",
                    description: "Deadline pro odevzdání všech projektů za Q4."
                },
                {
                    id: 5,
                    title: "Workshop: Nové technologie",
                    date: new Date(Date.now() + 20 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
                    type: "training",
                    description: "Workshop zaměřený na nové technologie a jejich implementaci v praxi."
                },
                {
                    id: 6,
                    title: "Týmový building",
                    date: new Date(Date.now() + 28 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
                    type: "social",
                    description: "Celodenní týmová aktivita v přírodě. Sraz v 8:00 u hlavního vchodu."
                },
                {
                    id: 7,
                    title: "Prezentace výsledků",
                    date: new Date(Date.now() + 35 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
                    type: "meeting",
                    description: "Prezentace výsledků projektu pro klienta. Připravte si podklady."
                },
                {
                    id: 8,
                    title: "Školení: Excel pro pokročilé",
                    date: new Date(Date.now() + 42 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
                    type: "training",
                    description: "Dvousemestrální školení pokročilých funkcí v Excelu."
                },
                {
                    id: 9,
                    title: "Pravidelná porada oddělení",
                    date: new Date(Date.now() + 1 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
                    type: "meeting",
                    description: "Týdenní porada oddělení. Připravte si report."
                },
                {
                    id: 10,
                    title: "Kulturní akce: Návštěva divadla",
                    date: new Date(Date.now() + 18 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
                    type: "social",
                    description: "Společná návštěva divadelního představení. Vstupenky zajistí HR."
                },
                {
                    id: 11,
                    title: "Hodnocení zaměstnanců",
                    date: new Date(Date.now() + 8 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
                    type: "deadline",
                    description: "Deadline pro odevzdání hodnocení zaměstnanců za uplynulé období."
                },
                {
                    id: 12,
                    title: "Školení: Komunikační dovednosti",
                    date: new Date(Date.now() + 25 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
                    type: "training",
                    description: "Školení měkkých dovedností – efektivní komunikace a prezentační dovednosti."
                },
                {
                    id: 13,
                    title: "Výroční zpráva",
                    date: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
                    type: "deadline",
                    description: "Termín odevzdání výroční zprávy za předchozí rok."
                },
                {
                    id: 14,
                    title: "Sportovní den",
                    date: new Date(Date.now() + 45 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
                    type: "social",
                    description: "Firemní sportovní den – fotbal, volejbal, běh. Přihlaste se u koordinátora."
                },
                {
                    id: 15,
                    title: "Strategické plánování",
                    date: new Date(Date.now() + 50 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
                    type: "meeting",
                    description: "Celodenní workshop strategického plánování pro další rok."
                }
            ];

            // --- Pomocné funkce ---
            function formatDate(dateStr) {
                const d = new Date(dateStr + 'T00:00:00');
                const day = d.getDate();
                const month = d.getMonth() + 1;
                const year = d.getFullYear();
                const days = ['Neděle', 'Pondělí', 'Úterý', 'Středa', 'Čtvrtek', 'Pátek', 'Sobota'];
                const dayName = days[d.getDay()];
                return `${day}. ${month}. ${year}`;
            }

            function getDayName(dateStr) {
                const d = new Date(dateStr + 'T00:00:00');
                const days = ['Ne', 'Po', 'Út', 'St', 'Čt', 'Pá', 'So'];
                return days[d.getDay()];
            }

            function getTypeClass(type) {
                switch (type) {
                    case 'meeting': return 'event-type-meeting';
                    case 'training': return 'event-type-training';
                    case 'social': return 'event-type-social';
                    case 'deadline': return 'event-type-deadline';
                    default: return 'event-type-other';
                }
            }

            function getTypeLabel(type) {
                switch (type) {
                    case 'meeting': return 'Porada';
                    case 'training': return 'Školení';
                    case 'social': return 'Společenská';
                    case 'deadline': return 'Termín';
                    default: return 'Jiné';
                }
            }

            function isPastEvent(dateStr) {
                const today = new Date();
                today.setHours(0, 0, 0, 0);
                const eventDate = new Date(dateStr + 'T00:00:00');
                return eventDate < today;
            }

            function escapeHtml(text) {
                if (!text) return '';
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            // --- Filtrování ---
            function getFilteredEvents() {
                const typeFilter = filterType.value;
                const searchTerm = filterSearch.value.toLowerCase().trim();

                return events.filter(event => {
                    if (typeFilter !== 'all' && event.type !== typeFilter) return false;
                    if (searchTerm) {
                        const title = (event.title || '').toLowerCase();
                        const desc = (event.description || '').toLowerCase();
                        if (!title.includes(searchTerm) && !desc.includes(searchTerm)) return false;
                    }
                    return true;
                });
            }

            // --- Vykreslení událostí ---
            function renderEvents() {
                const filtered = getFilteredEvents();

                // Řazení podle data (nejbližší první)
                filtered.sort((a, b) => a.date.localeCompare(b.date));

                if (filtered.length === 0) {
                    eventsList.innerHTML = `
                        <div class="no-events">
                            <span class="icon">📭</span>
                            ${events.length === 0 ? 'Zatím zde nejsou žádné události.' : 'Žádné události neodpovídají zadanému filtru.'}
                        </div>
                    `;
                    eventCount.innerHTML = `Celkem: <strong>0</strong> událostí`;
                    totalEventsSpan.textContent = '0';
                    return;
                }

                let html = '';
                filtered.forEach(event => {
                    const dateStr = formatDate(event.date);
                    const dayName = getDayName(event.date);
                    const typeClass = getTypeClass(event.type);
                    const typeLabel = getTypeLabel(event.type);
                    const description = event.description || '';
                    const past = isPastEvent(event.date);

                    html += `
                        <div class="event-card" style="${past ? 'opacity: 0.6;' : ''}">
                            <div class="event-date">
                                ${dateStr}
                                <span class="day-name">${dayName}${past ? ' (proběhlo)' : ''}</span>
                            </div>
                            <div class="event-body">
                                <div class="event-title">${escapeHtml(event.title)}</div>
                                ${description ? `<div class="event-description">${escapeHtml(description)}</div>` : ''}
                                <div class="event-meta">
                                    <span class="event-type ${typeClass}">${typeLabel}</span>
                                </div>
                            </div>
                        </div>
                    `;
                });

                eventsList.innerHTML = html;
                const countText = filtered.length === events.length 
                    ? `Celkem: <strong>${filtered.length}</strong> událostí`
                    : `Celkem: <strong>${filtered.length}</strong> událostí (z ${events.length} celkem)`;
                eventCount.innerHTML = countText;
                totalEventsSpan.textContent = filtered.length;
            }

            // --- Filtry ---
            filterType.addEventListener('change', renderEvents);
            filterSearch.addEventListener('input', renderEvents);

            clearFilterBtn.addEventListener('click', function() {
                filterType.value = 'all';
                filterSearch.value = '';
                renderEvents();
            });

            // --- Inicializace ---
            renderEvents();
        })();
    </script>
</body>
</html>