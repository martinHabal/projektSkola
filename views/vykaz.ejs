<!DOCTYPE html>
<html lang="cs">

  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 20px;
      background: #f7f7f7;
    }

    h1 {
      text-align: center;
      color: #333;
    }

    table {
      width: 80%;
      margin: 20px auto;
      border-collapse: collapse;
      background: white;
      box-shadow: 0 0 6px rgba(0,0,0,0.1);
      border-radius: 8px;
      overflow: hidden;
    }

    th, td {
      padding: 12px 15px;
      text-align: center;
    }

    th {
      background: #4CAF50;
      color: white;
    }

    tr:nth-child(even) {
      background: #f2f2f2;
    }

    tr:hover {
      background: #e6ffe6;
    }

    .ratio {
      color: #333;
      font-weight: bold;
    }
    .spinner {
    width: 50px;
    height: 50px;
    border: 5px solid #f3f3f3;
    border-top: 5px solid #3498db;
    border-radius: 50%;
    display: inline-block;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}
  </style>

<%- include('./partials/head') %>
<body>
    <%- include('./partials/header') %>

    <!-- Místo, kde chcete zobrazit spinner -->
<div id="loading-spinner" style="text-align: center; padding: 50px;">
    <div class="spinner"></div>
    <p style="margin-top: 15px; color: #666;">Načítám data...</p>
</div>

<!-- Sem se vykreslí data po načtení -->
<div id="data-content" style="display: none;">
    <!-- Váš obsah -->
</div>

<script>
    // Po načtení stránky
document.addEventListener('DOMContentLoaded', async function() {
    const spinner = document.getElementById('loading-spinner');
    const content = document.getElementById('data-content');
    
    try {
        // Vaše API volání zde...
        // (váš existující kód pro načítání dat)
        
        // Po načtení dat:
        spinner.style.display = 'none';  // Schovat spinner
        content.style.display = 'block'; // Zobrazit data
        
    } catch (error) {
        spinner.innerHTML = '<p style="color: red;">❌ Chyba při načítání</p>';
    }
});

</script>
  <h1>Přehled hodin učitelů za měsíc září</h1>
  <table>
    <thead>
      <tr>
        <th>Učitel ID</th>
        <th>Zkratka</th>
        <th>Počet hodin</th>
        <th>Své hodiny (bez suplovaných)</th>
        <th>Poměr vlastní/suplované (%)</th>
      </tr>
    </thead>
    <tbody>
      <% teacherSummary.forEach(t => { %>
        <tr>
          <td><%= t.teacher_id %></td>
          <td><%= t.teacher_abbr %></td>
          <td><%= t.total_lessons %></td>
          <td><%= t.same_teacher_count %></td>
          <td class="ratio">
            <%= ((t.same_teacher_count / t.total_lessons) * 100).toFixed(0) %> %
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <p>Cílem je, aby ucitel ten výkaz vůbec nemusel dělat. Jen si to zkontroluje</p>
  <p>Workflow:</p>
  <p></p>
</body>
</html>


