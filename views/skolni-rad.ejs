    // ------------------------------------------------------------------
    // 2. VYKRESLENÍ OBSAHU
    // ------------------------------------------------------------------
    const contentContainer = document.getElementById('content');
    const tocContainer = document.getElementById('toc');

    function renderContent() {
        let html = '';
        let tocHtml = '<ul>';

        schoolData.forEach((chapter, idx) => {
            const chapterId = `chap-${idx}`;
            html += `<div class="chapter" id="${chapterId}">`;
            html += `<h2>${chapter.chapter}</h2>`;

            tocHtml += `<li><a href="#${chapterId}" data-chapter="${idx}">${chapter.chapter}</a>`;
            if (chapter.subsections.length > 1 || (chapter.subsections.length === 1 && chapter.subsections[0].title)) {
                tocHtml += '<ul>';
                chapter.subsections.forEach((sub, subIdx) => {
                    if (sub.title) {
                        const subId = `${chapterId}-sub-${subIdx}`;
                        tocHtml += `<li><a href="#${subId}" data-chapter="${idx}" data-sub="${subIdx}">${sub.title}</a></li>`;
                    }
                });
                tocHtml += '</ul>';
            }
            tocHtml += '</li>';

            chapter.subsections.forEach((sub, subIdx) => {
                const subId = `${chapterId}-sub-${subIdx}`;
                const hasTitle = sub.title && sub.title.length > 0;
                html += `<div class="subsection" id="${subId}" data-chapter="${idx}" data-sub="${subIdx}">`;
                if (hasTitle) {
                    html += `<h3>${sub.title}</h3>`;
                }
                html += `<div class="sub-content">${sub.content}</div>`;
                html += `</div>`;
            });

            html += `</div>`;
        });

        tocHtml += '</ul>';
        contentContainer.innerHTML = html;
        tocContainer.innerHTML = tocHtml;

        // Po vykreslení uložíme originální HTML do data atributu
        document.querySelectorAll('.subsection').forEach(el => {
            const contentDiv = el.querySelector('.sub-content');
            if (contentDiv && !el.dataset.originalHtml) {
                el.dataset.originalHtml = contentDiv.innerHTML;
            }
        });
    }

    renderContent();

    // ------------------------------------------------------------------
    // 3. FULLTEXTOVÉ VYHLEDÁVÁNÍ (průběžné, bez tlačítka)
    // ------------------------------------------------------------------
    const searchInput = document.getElementById('search-input');
    const clearBtn = document.getElementById('clear-search');
    const searchInfo = document.getElementById('search-info');
    const searchResults = document.getElementById('search-results');
    const resultsList = document.getElementById('results-list');

    // Pomocná funkce pro získání názvu sekce (kapitola + podtitul)
    function getSectionTitle(subsectionEl) {
        const chapterEl = subsectionEl.closest('.chapter');
        const chapterTitle = chapterEl ? chapterEl.querySelector('h2')?.textContent || '' : '';
        const subTitleEl = subsectionEl.querySelector('h3');
        const subTitle = subTitleEl ? subTitleEl.textContent : '';
        if (subTitle) {
            return `${chapterTitle} – ${subTitle}`;
        }
        return chapterTitle;
    }

    function performSearch(query) {
        const trimmed = query.trim();
        if (!trimmed) {
            clearSearch();
            return;
        }

        const lowerQuery = trimmed.toLowerCase();
        let matchCount = 0;
        const matches = []; // pro seznam odkazů

        // Projdeme všechny podsekce
        const subsections = document.querySelectorAll('.subsection');
        subsections.forEach(el => {
            const contentDiv = el.querySelector('.sub-content');
            if (!contentDiv) return;

            // Obnovíme originální HTML
            const originalHtml = el.dataset.originalHtml || contentDiv.innerHTML;
            contentDiv.innerHTML = originalHtml;

            const text = contentDiv.innerText || '';
            if (text.toLowerCase().includes(lowerQuery)) {
                // Zvýrazníme
                const highlighted = highlightText(originalHtml, trimmed);
                contentDiv.innerHTML = highlighted;
                el.classList.remove('hidden-subsection');
                matchCount++;
                // Uložíme pro seznam
                const sectionId = el.id;
                const title = getSectionTitle(el);
                matches.push({ id: sectionId, title: title });
            } else {
                el.classList.add('hidden-subsection');
            }
        });

        // Skryjeme / zobrazíme kapitoly
        document.querySelectorAll('.chapter').forEach(ch => {
            const visibleSubs = ch.querySelectorAll('.subsection:not(.hidden-subsection)');
            if (visibleSubs.length === 0) {
                ch.classList.add('hidden-chapter');
            } else {
                ch.classList.remove('hidden-chapter');
            }
        });

        // Informace a seznam odkazů
        if (matchCount === 0) {
            searchInfo.textContent = `Žádná sekce neobsahuje „${trimmed}“.`;
            searchResults.classList.remove('visible');
        } else {
            searchInfo.textContent = `Nalezeno ${matchCount} sekcí obsahujících „${trimmed}“.`;
            // Sestavíme seznam odkazů
            resultsList.innerHTML = '';
            matches.forEach(m => {
                const li = document.createElement('li');
                const a = document.createElement('a');
                a.href = `#${m.id}`;
                a.textContent = m.title || 'Bez názvu';
                a.addEventListener('click', function(e) {
                    e.preventDefault();
                    const target = document.getElementById(m.id);
                    if (target) {
                        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                        // Zvýrazníme aktivní odkaz v sidebaru?
                        document.querySelectorAll('#toc a').forEach(link => link.classList.remove('active'));
                        // Najdeme odpovídající odkaz v toc
                        const tocLink = document.querySelector(`#toc a[href="#${m.id}"]`);
                        if (tocLink) tocLink.classList.add('active');
                    }
                });
                li.appendChild(a);
                resultsList.appendChild(li);
            });
            searchResults.classList.add('visible');
        }
    }

    function highlightText(html, query) {
        // Použijeme DOM traversal pro bezpečné zvýraznění
        const temp = document.createElement('div');
        temp.innerHTML = html;
        const lowerQuery = query.toLowerCase();

        function walk(node) {
            if (node.nodeType === 3) { // text
                const text = node.nodeValue;
                if (text.toLowerCase().includes(lowerQuery)) {
                    const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
                    const parts = text.split(regex);
                    const frag = document.createDocumentFragment();
                    parts.forEach(part => {
                        if (part && part.toLowerCase() === lowerQuery) {
                            const mark = document.createElement('mark');
                            mark.className = 'highlight';
                            mark.textContent = part;
                            frag.appendChild(mark);
                        } else if (part) {
                            frag.appendChild(document.createTextNode(part));
                        }
                    });
                    node.parentNode.replaceChild(frag, node);
                }
            } else {
                for (let child of node.childNodes) {
                    walk(child);
                }
            }
        }

        walk(temp);
        return temp.innerHTML;
    }

    function clearSearch() {
        // Obnovíme všechny podsekce
        document.querySelectorAll('.subsection').forEach(el => {
            const contentDiv = el.querySelector('.sub-content');
            if (contentDiv && el.dataset.originalHtml) {
                contentDiv.innerHTML = el.dataset.originalHtml;
            }
            el.classList.remove('hidden-subsection');
        });
        document.querySelectorAll('.chapter').forEach(ch => {
            ch.classList.remove('hidden-chapter');
        });
        searchInput.value = '';
        searchInfo.textContent = '';
        searchResults.classList.remove('visible');
        resultsList.innerHTML = '';
    }

    // Průběžné vyhledávání při psaní
    searchInput.addEventListener('input', function() {
        performSearch(this.value);
    });

    // Tlačítko zrušit
    clearBtn.addEventListener('click', clearSearch);

    // ------------------------------------------------------------------
    // 4. AKTIVNÍ ODKAZY V SIDEBARU
    // ------------------------------------------------------------------
    document.querySelectorAll('#toc a').forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            const targetId = this.getAttribute('href').substring(1);
            const target = document.getElementById(targetId);
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                document.querySelectorAll('#toc a').forEach(a => a.classList.remove('active'));
                this.classList.add('active');
            }
        });
    });

    console.log('Školní řád načten – vyhledávání je průběžné a zobrazuje seznam odkazů.');
</script>
