
    <style>
        /* * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        } */
        /* body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f5f7fa;
            color: #1e2a3a;
            line-height: 1.6;
        } */

        #app {
            display: flex;
            flex-direction: row;
            min-height: 100vh;
            max-width: 1600px;
            margin: 0 auto;
            background: #fff;
            box-shadow: 0 0 20px rgba(0,0,0,0.05);
        }

        #left {
            flex: 1;
            padding: 2rem 2.5rem;
            overflow-y: auto;
            min-width: 0;
        }

        #right {
            width: 380px;
            background: #f8faff;
            border-left: 1px solid #dce1e8;
            padding: 1.5rem 1.2rem;
            position: sticky;
            top: 0;
            height: 100vh;
            overflow-y: auto;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
        }

        #right h2 {
            font-size: 1.2rem;
            color: #0b2b4a;
            display: flex;
            align-items: center;
            gap: 0.6rem;
            border-bottom: 2px solid #b0c4d9;
            padding-bottom: 0.5rem;
            margin-bottom: 0.5rem;
        }

        .server-status {
            font-size: 0.75rem;
            padding: 0.2rem 0.8rem;
            border-radius: 20px;
            margin-bottom: 0.5rem;
            display: inline-block;
        }
        .server-status.online {
            background: #dcfce7;
            color: #166534;
        }
        .server-status.offline {
            background: #fee2e2;
            color: #991b1b;
        }
        .server-status.checking {
            background: #fef3c7;
            color: #92400e;
        }

        .ai-status {
            font-size: 0.8rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            margin-bottom: 0.8rem;
        }
        .ai-status .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
            background: #22c55e;
            transition: background 0.3s;
        }
        .ai-status .dot.loading {
            background: #f59e0b;
            animation: pulse 1s infinite;
        }
        .ai-status .dot.error {
            background: #ef4444;
        }
        .ai-status .dot.offline {
            background: #94a3b8;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }

        .ai-chat {
            flex: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
            padding: 0.2rem 0;
            min-height: 300px;
            max-height: 450px;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 0.8rem;
            background: white;
        }
        .ai-message {
            max-width: 92%;
            padding: 0.6rem 1rem;
            border-radius: 14px;
            font-size: 0.9rem;
            line-height: 1.5;
            word-break: break-word;
            animation: fadeUp 0.2s ease;
        }
        .ai-message.user {
            background: #dce6f5;
            align-self: flex-end;
            border-bottom-right-radius: 4px;
        }
        .ai-message.assistant {
            background: #f1f5f9;
            align-self: flex-start;
            border-bottom-left-radius: 4px;
        }
        .ai-message .msg-icon { margin-right: 4px; }
        .ai-message.error {
            background: #fee2e2;
            color: #991b1b;
        }

        .typing-indicator {
            display: inline-flex;
            gap: 4px;
        }
        .typing-indicator span {
            width: 6px;
            height: 6px;
            background: #94a3b8;
            border-radius: 50%;
            animation: typing 1.2s infinite;
        }
        .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
        .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

        @keyframes typing {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-6px); }
        }

        @keyframes fadeUp {
            0% { opacity: 0; transform: translateY(6px); }
            100% { opacity: 1; transform: translateY(0); }
        }

        .ai-input-area {
            display: flex;
            gap: 0.4rem;
            padding: 0.8rem 0 0.2rem 0;
            flex-wrap: wrap;
            align-items: center;
            border-top: 1px solid #dce1e8;
            margin-top: 0.6rem;
            padding-top: 0.8rem;
        }
        .ai-input-area input {
            flex: 1;
            padding: 0.5rem 1rem;
            border-radius: 40px;
            border: 1px solid #cbd5e1;
            font-size: 0.9rem;
            min-width: 100px;
            background: white;
        }
        .ai-input-area input:focus {
            outline: 2px solid #3b82f6;
            border-color: transparent;
        }
        .ai-input-area .btn {
            padding: 0.4rem 1rem;
            border-radius: 40px;
            border: none;
            background: #1e3a5f;
            color: white;
            font-weight: 500;
            cursor: pointer;
            font-size: 0.85rem;
            transition: 0.15s;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }
        .ai-input-area .btn:hover { background: #0b2b4a; }
        .ai-input-area .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        .ai-input-area .btn-voice {
            background: #eef2f6;
            color: #1e2a3a;
            border: 1px solid #cbd5e1;
        }
        .ai-input-area .btn-voice:hover { background: #e2e8f0; }
        .ai-input-area .btn-voice.recording {
            background: #fce8e8;
            color: #b33;
        }
        .voice-indicator {
            font-size: 0.75rem;
            color: #475569;
            display: none;
            align-items: center;
            gap: 0.3rem;
        }
        .voice-indicator.active { display: inline-flex; }

        .clear-chat-btn {
            background: none;
            border: none;
            color: #94a3b8;
            cursor: pointer;
            font-size: 0.8rem;
            padding: 0.2rem 0.5rem;
        }
        .clear-chat-btn:hover {
            color: #ef4444;
        }
        .ai-header-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* SEARCH */
        #search-box {
            margin-bottom: 1rem;
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            align-items: center;
        }
        #search-box input {
            flex: 1;
            padding: 0.7rem 1rem;
            border: 2px solid #cbd5e1;
            border-radius: 30px;
            font-size: 1rem;
            outline: none;
            min-width: 200px;
        }
        #search-box input:focus {
            border-color: #2a6b9c;
        }
        #search-box button {
            padding: 0.7rem 1.5rem;
            background: #8b9aaa;
            color: #fff;
            border: none;
            border-radius: 30px;
            font-size: 1rem;
            cursor: pointer;
            transition: background 0.2s;
            white-space: nowrap;
        }
        #search-box button:hover {
            background: #6a7b8e;
        }

        #search-info {
            font-size: 0.9rem;
            color: #4a5b6e;
            margin-bottom: 0.5rem;
            min-height: 1.5rem;
        }

        #search-results {
            margin-bottom: 1.5rem;
            padding: 0.8rem 1rem;
            background: #f8faff;
            border-radius: 8px;
            border: 1px solid #dce1e8;
            display: none;
        }
        #search-results.visible {
            display: block;
        }
        #search-results ul {
            list-style: none;
            padding: 0;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem 1.2rem;
        }
        #search-results ul li a {
            color: #1e3a5f;
            text-decoration: none;
            border-bottom: 1px dashed #b0c4d9;
            font-size: 0.9rem;
            cursor: pointer;
        }

        /* CONTENT */
        .chapter {
            margin-bottom: 2.5rem;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 1.5rem;
        }
        .chapter:last-child { border-bottom: none; }
        .chapter h2 {
            font-size: 1.8rem;
            color: #0b2b4a;
            margin-bottom: 1rem;
            padding-bottom: 0.3rem;
            border-bottom: 3px solid #cbd5e1;
        }
        .subsection {
            margin-top: 1.2rem;
            padding-left: 0.2rem;
        }
        .subsection h3 {
            font-size: 1.2rem;
            color: #1e3a5f;
            margin-bottom: 0.5rem;
            font-weight: 600;
        }
        .subsection p, .subsection li { margin-bottom: 0.6rem; }
        .subsection ul, .subsection ol { padding-left: 1.8rem; margin-bottom: 0.6rem; }
        .subsection table {
            border-collapse: collapse;
            margin: 1rem 0;
            width: 100%;
            max-width: 400px;
        }
        .subsection table td, .subsection table th {
            border: 1px solid #b0c4d9;
            padding: 0.4rem 0.8rem;
            text-align: center;
        }
        .subsection table th { background: #e8edf4; font-weight: 600; }
        .highlight {
            background-color: #f9e66b;
            padding: 0.1rem 0.2rem;
            border-radius: 2px;
            font-weight: 600;
        }
        .hidden-chapter { display: none; }
        .hidden-subsection { display: none; }

        .footnote {
            font-size: 0.9rem;
            color: #4a5b6e;
            margin-top: 1rem;
            border-top: 1px dashed #dce1e8;
            padding-top: 0.8rem;
        }

        @media (max-width: 1024px) {
            #right { width: 320px; padding: 1rem; }
        }

        @media (max-width: 820px) {
            #app { flex-direction: column; }
            #right {
                width: 100%;
                height: auto;
                position: relative;
                border-left: none;
                border-top: 1px solid #dce1e8;
                padding: 1rem;
                max-height: 450px;
                overflow-y: auto;
            }
            #left { padding: 1rem; }
            .ai-chat { max-height: 200px; min-height: 150px; }
        }
    </style>
    

<%- include('./partials/head') %>
<body>
   
      <%- include('./partials/header') %>
<div id="app">

    <!-- ===== LEVÁ ČÁST ===== -->
    <div id="left">
        <div id="search-box">
            <input type="text" id="search-input" placeholder="🔍 Hledat ve školním řádu" />
            <button id="clear-search">✕ Zrušit</button>
        </div>
        <div id="search-info"></div>
        <div id="search-results">
            <h4>⬇️ Nalezené sekce</h4>
            <ul id="results-list"></ul>
        </div>
        <div id="content"></div>
        <div class="footnote">Školní řád nabývá účinnosti dnem 1. září 2025.</div>
    </div>

    <!-- ===== PRAVÝ SLOUPEC – AI AGENT ===== -->
    <aside id="right">
        <div class="ai-header-row">
            <h2><span class="fa fa-robot"></span> AI asistent</h2>
            <button class="clear-chat-btn" id="clearChatBtn">✕ Smazat</button>
        </div>

        <div>
            <span class="server-status checking" id="serverStatus">⏳ Kontrola připojení...</span>
        </div>

        <div class="ai-status">
            <span class="dot" id="aiStatusDot"></span>
            <span id="aiStatusText">Připraven</span>
        </div>

        <div class="ai-chat" id="aiChat">
            <div class="ai-message assistant">
                <span class="msg-icon">🤖</span> Dobrý den, jsem AI asistent. Zeptejte se mě na cokoli ohledně školního řádu.
            </div>
        </div>

        <div class="ai-input-area">
            <input type="text" id="aiInput" placeholder="Napište dotaz..." />
            <button class="btn" id="aiSendBtn"><span class="fa fa-paper-plane"></span></button>
            <button class="btn btn-voice" id="aiVoiceInputBtn">
                <span class="fa fa-microphone"></span>
            </button>
            <button class="btn btn-voice" id="aiVoiceOutputBtn">
                <span class="fa fa-volume-up"></span>
            </button>
            <span class="voice-indicator" id="aiVoiceIndicator">
                <span class="fa fa-circle" style="color: #d94a4a; font-size: 0.5rem;"></span> poslouchám...
            </span>
        </div>
    </aside>
</div>

<script>
    // ================================================================
    // 1. DATA – ŠKOLNÍ ŘÁD
    // ================================================================
    const schoolData = [
        {
            chapter: "Úvod",
            subsections: [
                {
                    title: "",
                    content: `
                        <p><strong>Hotelová škola Mariánské Lázně, příspěvková organizace</strong></p>
                        <h1 style="font-size:2.2rem; color:#0b2b4a; margin:0.2rem 0;">ŠKOLNÍ ŘÁD</h1>
                        <p>Školní řád upravuje v souladu s § 30 zákona č. 561/2004 Sb. podmínky soužití na škole.</p>
                        <p>Školní řád je závazný pro všechny žáky školy, jejich zákonné zástupce a všechny zaměstnance školy.</p>
                    `
                }
            ]
        },
        {
            chapter: "I. Provoz školy",
            subsections: [
                {
                    title: "1. Systém zabezpečení vstupu",
                    content: `
                        <p><strong>a)</strong> V době teoretického vyučování je žákům umožněn vstup do budovy školy od 7:30 hod.</p>
                        <p><strong>b)</strong> Každý žák má povinnost zaznamenat svůj příchod přiděleným čipem.</p>
                        <p><strong>c)</strong> Žák přichází do školy alespoň 10 minut před zahájením vyučování.</p>
                        <p><strong>d)</strong> Zahájení vyučování je v 8.00 hod.</p>
                    `
                },
                {
                    title: "2. Organizace vyučovacího dne",
                    content: `
                        <p>Vyučovací hodiny: 8.00–8.45, 8.50–9.35, 9.55–10.40, 10.50–11.35, 11.45–12.30</p>
                    `
                }
            ]
        },
        {
            chapter: "II. Práva a povinnosti žáků",
            subsections: [
                {
                    title: "1. Práva žáků",
                    content: `
                        <p>Žák má právo na poskytování kvalitního vzdělání, na informace o průběhu a výsledcích svého vzdělávání.</p>
                    `
                },
                {
                    title: "2. Povinnosti žáků",
                    content: `
                        <p>Žák je povinen řádně docházet do školy, dodržovat školní řád, respektovat pokyny pedagogických pracovníků.</p>
                    `
                }
            ]
        },
        {
            chapter: "III. Zákazy",
            subsections: [
                {
                    title: "",
                    content: `
                        <p>Žákům je zakázáno vstupovat do školy pod vlivem alkoholu, požívat alkoholické nápoje, kouřit v prostorách školy, přinášet nebezpečné předměty.</p>
                    `
                }
            ]
        }
    ];

    // ================================================================
    // 2. RENDER OBSAHU
    // ================================================================
    const contentContainer = document.getElementById('content');

    function renderContent() {
        let html = '';
        schoolData.forEach((chapter, idx) => {
            const chapterId = `chap-${idx}`;
            html += `<div class="chapter" id="${chapterId}">`;
            html += `<h2>${chapter.chapter}</h2>`;

            chapter.subsections.forEach((sub, subIdx) => {
                const subId = `${chapterId}-sub-${subIdx}`;
                const hasTitle = sub.title && sub.title.length > 0;
                html += `<div class="subsection" id="${subId}">`;
                if (hasTitle) html += `<h3>${sub.title}</h3>`;
                html += `<div class="sub-content">${sub.content}</div>`;
                html += `</div>`;
            });
            html += `</div>`;
        });
        contentContainer.innerHTML = html;

        document.querySelectorAll('.subsection').forEach(el => {
            const contentDiv = el.querySelector('.sub-content');
            if (contentDiv && !el.dataset.originalHtml) {
                el.dataset.originalHtml = contentDiv.innerHTML;
            }
        });
    }
    renderContent();

    // ================================================================
    // 3. VYHLEDÁVÁNÍ
    // ================================================================
    const searchInput = document.getElementById('search-input');
    const clearBtn = document.getElementById('clear-search');
    const searchInfo = document.getElementById('search-info');
    const searchResults = document.getElementById('search-results');
    const resultsList = document.getElementById('results-list');

    function performSearch(query) {
        const trimmed = query.trim();
        if (!trimmed) {
            document.querySelectorAll('.subsection').forEach(el => {
                const cd = el.querySelector('.sub-content');
                if (cd && el.dataset.originalHtml) cd.innerHTML = el.dataset.originalHtml;
                el.classList.remove('hidden-subsection');
            });
            document.querySelectorAll('.chapter').forEach(ch => ch.classList.remove('hidden-chapter'));
            searchInput.value = '';
            searchInfo.textContent = '';
            searchResults.classList.remove('visible');
            resultsList.innerHTML = '';
            return;
        }

        const lower = trimmed.toLowerCase();
        let matches = [];

        document.querySelectorAll('.subsection').forEach(el => {
            const cd = el.querySelector('.sub-content');
            if (!cd) return;
            if (el.dataset.originalHtml) cd.innerHTML = el.dataset.originalHtml;
            const text = cd.innerText || '';
            if (text.toLowerCase().includes(lower)) {
                el.classList.remove('hidden-subsection');
                const chapterEl = el.closest('.chapter');
                const chapterTitle = chapterEl?.querySelector('h2')?.textContent || '';
                const subTitle = el.querySelector('h3')?.textContent || '';
                const title = subTitle ? `${chapterTitle} – ${subTitle}` : chapterTitle;
                matches.push({ id: el.id, title: title });
                const regex = new RegExp(`(${trimmed.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
                cd.innerHTML = cd.innerHTML.replace(regex, '<mark class="highlight">$1</mark>');
            } else {
                el.classList.add('hidden-subsection');
            }
        });

        document.querySelectorAll('.chapter').forEach(ch => {
            const visible = ch.querySelectorAll('.subsection:not(.hidden-subsection)');
            ch.classList.toggle('hidden-chapter', visible.length === 0);
        });

        if (matches.length === 0) {
            searchInfo.textContent = `Žádná sekce neobsahuje "${trimmed}".`;
            searchResults.classList.remove('visible');
        } else {
            searchInfo.textContent = `Nalezeno ${matches.length} sekcí.`;
            resultsList.innerHTML = matches.map(m =>
                `<li><a href="#${m.id}" onclick="document.getElementById('${m.id}').scrollIntoView({behavior:'smooth'})">${m.title}</a></li>`
            ).join('');
            searchResults.classList.add('visible');
        }
    }

    searchInput.addEventListener('input', () => performSearch(searchInput.value));
    clearBtn.addEventListener('click', () => performSearch(''));

    // ================================================================
    // 4. AI AGENT – KOMUNIKACE S BACKENDEM
    // ================================================================
    const aiChat = document.getElementById('aiChat');
    const aiInput = document.getElementById('aiInput');
    const aiSendBtn = document.getElementById('aiSendBtn');
    const aiStatusDot = document.getElementById('aiStatusDot');
    const aiStatusText = document.getElementById('aiStatusText');
    const clearChatBtn = document.getElementById('clearChatBtn');
    const serverStatus = document.getElementById('serverStatus');

    // --- Ověření, že backend běží ---
    async function checkBackend() {
        try {
            console.log('🔍 Kontrola backendu na /api/test...');
            const response = await fetch('/api/test');
            if (response.ok) {
                const data = await response.json();
                console.log('✅ Backend online:', data);
                serverStatus.className = 'server-status online';
                serverStatus.textContent = '✅ Backend online';
                return true;
            } else {
                throw new Error('Backend neodpovídá');
            }
        } catch (e) {
            console.error('❌ Backend nedostupný:', e.message);
            serverStatus.className = 'server-status offline';
            serverStatus.textContent = '❌ Backend nedostupný (spusťte node server.js)';
            return false;
        }
    }

    // Sestavení kontextu pro AI
    function buildSystemPrompt() {
        let fullText = '';
        schoolData.forEach(chapter => {
            fullText += `\n--- ${chapter.chapter} ---\n`;
            chapter.subsections.forEach(sub => {
                if (sub.title) fullText += `\n${sub.title}:\n`;
                fullText += sub.content.replace(/<[^>]*>/g, ' ') + '\n';
            });
        });
        return `Jsi užitečný asistent pro Hotelovou školu Mariánské Lázně. Odpovídej výhradně na základě tohoto školního řádu. Pokud odpověď v řádu nenajdeš, řekni to. Školní řád:\n${fullText}`;
    }

    const systemPrompt = buildSystemPrompt();
    let conversationHistory = [
        { role: 'system', content: systemPrompt }
    ];

    // --- Odeslání dotazu na backend ---
    async function sendToAI(query) {
        try {
            console.log('📤 Odesílám dotaz na /api/chat:', query.substring(0, 50) + '...');
            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    messages: conversationHistory.concat([
                        { role: 'user', content: query }
                    ])
                })
            });

            if (!response.ok) {
                const errorData = await response.json();
                console.error('❌ Backend vrátil chybu:', errorData);
                throw new Error(errorData.error || 'Neznámá chyba');
            }

            const data = await response.json();
            console.log('✅ Odpověď přijata z backendu');
            return data.reply;
        } catch (error) {
            console.error('❌ Chyba v sendToAI:', error.message);
            throw error;
        }
    }

    // --- UI funkce ---
    function addAiMessage(text, type, isError = false) {
        const msgDiv = document.createElement('div');
        msgDiv.className = `ai-message ${type}${isError ? ' error' : ''}`;
        const icon = type === 'user' ? '🧑' : '🤖';
        msgDiv.innerHTML = `<span class="msg-icon">${icon}</span> ${text}`;
        aiChat.appendChild(msgDiv);
        aiChat.scrollTop = aiChat.scrollHeight;
    }

    function addTypingIndicator() {
        const el = document.createElement('div');
        el.className = 'ai-message assistant';
        el.id = 'typingIndicator';
        el.innerHTML = `
            <span class="msg-icon">🤖</span>
            <span class="typing-indicator"><span></span><span></span><span></span></span>
        `;
        aiChat.appendChild(el);
        aiChat.scrollTop = aiChat.scrollHeight;
    }

    function removeTypingIndicator() {
        document.getElementById('typingIndicator')?.remove();
    }

    async function processAiQuery(query) {
        if (!query.trim()) return;

        // Kontrola backendu
        const isOnline = await checkBackend();
        if (!isOnline) {
            addAiMessage('❌ Backend není dostupný. Spusťte server příkazem: node server.js', 'assistant', true);
            return;
        }

        addAiMessage(query, 'user');
        aiInput.value = '';
        aiSendBtn.disabled = true;
        aiStatusDot.className = 'dot loading';
        aiStatusText.textContent = 'Přemýšlím...';

        addTypingIndicator();

        try {
            const response = await sendToAI(query);
            removeTypingIndicator();

            conversationHistory.push({ role: 'user', content: query });
            conversationHistory.push({ role: 'assistant', content: response });

            addAiMessage(response, 'assistant');
            lastAssistantReply = response;
            aiStatusDot.className = 'dot';
            aiStatusText.textContent = 'Odpovězeno';
            setTimeout(() => {
                aiStatusText.textContent = 'Připraven';
            }, 2000);
        } catch (error) {
            removeTypingIndicator();
            const errorMsg = error.message || 'Neznámá chyba';
            addAiMessage(`❌ Chyba: ${errorMsg}`, 'assistant', true);
            aiStatusDot.className = 'dot error';
            aiStatusText.textContent = 'Chyba';
        } finally {
            aiSendBtn.disabled = false;
        }
    }

    let lastAssistantReply = 'Dobrý den, jsem AI asistent.';

    aiSendBtn.addEventListener('click', () => processAiQuery(aiInput.value));
    aiInput.addEventListener('keyup', (e) => {
        if (e.key === 'Enter') processAiQuery(aiInput.value);
    });

    clearChatBtn.addEventListener('click', function() {
        if (confirm('Smazat konverzaci?')) {
            conversationHistory = [{ role: 'system', content: systemPrompt }];
            aiChat.innerHTML = `
                <div class="ai-message assistant">
                    <span class="msg-icon">🤖</span> Konverzace byla vymazána.
                </div>
            `;
            lastAssistantReply = 'Konverzace byla vymazána.';
            aiStatusDot.className = 'dot';
            aiStatusText.textContent = 'Připraven';
        }
    });

    // ================================================================
    // 5. HLASOVÝ VSTUP
    // ================================================================
    const aiVoiceInputBtn = document.getElementById('aiVoiceInputBtn');
    const aiVoiceIndicator = document.getElementById('aiVoiceIndicator');

    let recognition = null;
    let isRecording = false;

    if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        recognition = new SpeechRecognition();
        recognition.lang = 'cs-CZ';
        recognition.continuous = false;
        recognition.interimResults = false;

        recognition.onstart = function() {
            isRecording = true;
            aiVoiceInputBtn.classList.add('recording');
            aiVoiceIndicator.classList.add('active');
            aiStatusText.textContent = 'Poslouchám...';
            aiStatusDot.className = 'dot loading';
        };

        recognition.onresult = function(event) {
            const transcript = event.results[0][0].transcript;
            aiVoiceInputBtn.classList.remove('recording');
            aiVoiceIndicator.classList.remove('active');
            aiInput.value = transcript;
            processAiQuery(transcript);
        };

        recognition.onerror = function(event) {
            aiVoiceInputBtn.classList.remove('recording');
            aiVoiceIndicator.classList.remove('active');
            if (event.error !== 'not-allowed') {
                aiStatusDot.className = 'dot error';
                aiStatusText.textContent = 'Chyba mikrofonu';
            }
            setTimeout(() => {
                aiStatusText.textContent = 'Připraven';
                aiStatusDot.className = 'dot';
            }, 2000);
        };

        recognition.onend = function() {
            isRecording = false;
            aiVoiceInputBtn.classList.remove('recording');
            aiVoiceIndicator.classList.remove('active');
        };
    }

    aiVoiceInputBtn.addEventListener('click', function() {
        if (!recognition) {
            alert('Web Speech API není podporována.');
            return;
        }
        if (isRecording) { recognition.stop(); return; }
        try { recognition.start(); } catch (e) {}
    });

    // ================================================================
    // 6. HLASOVÝ VÝSTUP
    // ================================================================
    const aiVoiceOutputBtn = document.getElementById('aiVoiceOutputBtn');

    aiVoiceOutputBtn.addEventListener('click', function() {
        if (!lastAssistantReply || lastAssistantReply === 'Dobrý den, jsem AI asistent.') {
            alert('Žádná odpověď k přehrání.');
            return;
        }
        if ('speechSynthesis' in window) {
            const utterance = new SpeechSynthesisUtterance(lastAssistantReply);
            utterance.lang = 'cs-CZ';
            utterance.rate = 1.0;
            speechSynthesis.speak(utterance);
        }
    });

    // ================================================================
    // 7. INICIALIZACE
    // ================================================================
    checkBackend();
    console.log('✅ Aplikace načtena. Backend musí běžet na http://localhost:3000');
    console.log('📋 Systémový prompt:', systemPrompt.substring(0, 100) + '...');
</script>
</body>
</html>